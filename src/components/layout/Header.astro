---
import { AccentPicker } from '../theme/AccentPicker';
import { ThemeToggle } from '../theme/ThemeToggle';

const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/projects', label: 'Projects' },
  { href: '/writing', label: 'Writing' },
  { href: '/reading', label: 'Reading' },
  { href: '/about', label: 'About' },
];
---

<header class="w-full border-b border-[var(--border)]">
  <div class="max-w-[var(--content-max-width)] mx-auto px-6 md:px-8 lg:px-10">
    <nav class="flex items-center justify-between gap-4 py-4" aria-label="Main navigation">

      <!-- Site title -->
      <a
        href="/"
        class="font-serif font-semibold text-[1.125rem] text-[var(--text)] tracking-tight no-underline border-b-0 hover:text-[var(--accent)] hover:opacity-100 transition-colors duration-150"
        aria-label="Hamish — Home"
        aria-current={pathname === '/' ? 'page' : undefined}
      >
        Hamish
      </a>

      <!-- Nav links (hidden on mobile) -->
      <div class="hidden sm:flex items-center gap-8" role="list">
        {navLinks.map(({ href, label }) => {
          const isActive = pathname === href || pathname.startsWith(href + '/');
          return (
            <a
              href={href}
              role="listitem"
              class={[
                'text-sm font-medium no-underline border-b-0 relative transition-colors duration-150',
                isActive
                  ? 'text-[var(--accent)] after:absolute after:bottom-[-4px] after:left-0 after:right-0 after:h-[2px] after:bg-[var(--accent)] after:content-[\'\']'
                  : 'text-[var(--text-muted)] hover:text-[var(--accent)]',
              ].join(' ')}
              aria-current={isActive ? 'page' : undefined}
            >
              {label}
            </a>
          );
        })}
      </div>

      <!-- Theme controls -->
      <div class="flex items-center gap-2">
        <AccentPicker client:load />
        <ThemeToggle client:load />
      </div>

    </nav>
  </div>
</header>

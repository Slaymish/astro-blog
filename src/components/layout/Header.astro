---
import Logo from '../ui/Logo.astro';
import ButtonLink from '../ui/ButtonLink.astro';
import { BOOKING_URL } from '../../lib/site';

const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/work', label: 'Work' },
  { href: '/about', label: 'About' },
];

function navLinkClasses(href: string) {
  const isActive = pathname === href || pathname.startsWith(href + '/');
  return {
    class: [
      'site-nav__link',
      isActive
        ? 'site-nav__link--active'
        : '',
    ].join(' '),
    'aria-current': isActive ? ('page' as const) : undefined,
  };
}
---

<header id="site-header">
  <nav class="site-nav" aria-label="Primary navigation">
    <div class="site-nav__inner">
      <a
        id="nav-logo-link"
        href="/"
        class="nav-logo"
        aria-label="Hamish Burke, home"
        aria-current={pathname === '/' ? 'page' : undefined}
      >
        <Logo size={36} />
      </a>

      <div class="site-nav__desktop" role="list">
        {navLinks.map(({ href, label }) => (
          <a href={href} role="listitem" {...navLinkClasses(href)}>
            {label}
          </a>
        ))}
      </div>

      <div class="site-nav__actions">
        <ButtonLink
          href={BOOKING_URL}
          external
          ariaLabel="Book a call on Cal.com"
          class="site-nav__booking"
        >
          <span class="site-nav__booking-long">Book a call</span>
          <span class="site-nav__booking-short">Book</span>
        </ButtonLink>

        <details class="site-nav__mobile">
          <summary aria-label="Open navigation menu">
            <svg class="menu-icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="3" y1="6" x2="21" y2="6"/>
              <line x1="3" y1="12" x2="21" y2="12"/>
              <line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
            <svg class="menu-icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </summary>
          <div class="site-nav__mobile-panel">
            {navLinks.map(({ href, label }) => (
              <a href={href} {...navLinkClasses(href)}>{label}</a>
            ))}
          </div>
        </details>
      </div>
    </div>
  </nav>
</header>

<style>
  #site-header {
    background: var(--color-bg-canvas);
    border-bottom: 1px solid var(--color-stroke-subtle);
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
  }

  .site-nav__inner {
    align-items: center;
    display: flex;
    gap: var(--spacing-4);
    justify-content: space-between;
    margin-inline: auto;
    max-width: var(--content-max-width);
    min-height: 4.25rem;
    padding-inline: var(--page-gutter);
  }

  .site-nav__desktop {
    align-items: center;
    display: none;
    gap: clamp(1.5rem, 3vw, 2.5rem);
    margin-inline-start: auto;
  }

  .site-nav__link {
    color: var(--color-text-secondary);
    display: inline-flex;
    font-size: var(--type-label);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.1em;
    min-height: 2.75rem;
    align-items: center;
    text-decoration: none;
    text-transform: uppercase;
  }

  .site-nav__link:hover,
  .site-nav__link--active {
    color: var(--color-action);
    opacity: 1;
  }

  .site-nav__actions {
    align-items: center;
    display: flex;
    gap: var(--spacing-2);
  }

  .site-nav__booking-long {
    display: none;
  }

  .site-nav__mobile {
    position: relative;
  }

  .site-nav__mobile summary {
    align-items: center;
    color: var(--color-text-primary);
    cursor: pointer;
    display: flex;
    height: 2.75rem;
    justify-content: center;
    list-style: none;
    width: 2.75rem;
  }

  .site-nav__mobile summary::-webkit-details-marker {
    display: none;
  }

  .menu-icon-close,
  .site-nav__mobile[open] .menu-icon-open {
    display: none;
  }

  .site-nav__mobile[open] .menu-icon-close {
    display: block;
  }

  .site-nav__mobile-panel {
    background: var(--color-bg-canvas);
    border: 1px solid var(--color-stroke-subtle);
    display: flex;
    flex-direction: column;
    min-width: min(16rem, calc(100vw - 2 * var(--page-gutter)));
    padding: var(--spacing-3);
    position: absolute;
    right: 0;
    top: calc(100% + var(--spacing-3));
  }

  @media (min-width: 48rem) {
    .site-nav__inner {
      min-height: 4.5rem;
    }

    .site-nav__desktop {
      display: flex;
    }

    .site-nav__booking-long {
      display: inline;
    }

    .site-nav__booking-short,
    .site-nav__mobile {
      display: none;
    }
  }
</style>

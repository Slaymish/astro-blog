---
import { CONTACT_EMAIL } from '../../lib/site';
import Logo from '../ui/Logo.astro';
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__meta">
      <a href="/" class="footer-logo" aria-label="Hamish Burke, home"><Logo size={28} /></a>
      <p>Independent software work from Wellington, NZ.</p>

      <nav aria-label="Footer navigation">
        <a href="/work">Work</a>
        <a href="/about">About</a>
        <a href="/cv">CV</a>
      </nav>

      <div class="site-footer__profiles">
        <a href={`mailto:${CONTACT_EMAIL}`}>Email</a>
        <a href="https://github.com/Slaymish" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://www.linkedin.com/in/hamish-burke-2301669a" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>

      <p class="site-footer__copyright">&copy; {currentYear} Hamish Burke</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-stroke-subtle);
    margin-block-start: auto;
    padding-block: 2rem;
  }

  .site-footer__inner {
    margin-inline: auto;
    max-width: var(--content-max-width);
  }

  .site-footer__meta {
    align-items: start;
    border-top: 1px solid var(--color-stroke-subtle);
    color: var(--color-text-secondary);
    display: grid;
    font-size: var(--type-label);
    gap: var(--spacing-5);
    padding-block-start: var(--spacing-6);
  }

  .site-footer__meta p {
    line-height: 1.5;
    margin: 0;
  }

  .site-footer nav,
  .site-footer__profiles {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-3) var(--spacing-5);
  }

  .site-footer nav a,
  .site-footer__profiles a {
    align-items: center;
    color: var(--color-text-secondary);
    display: inline-flex;
    min-height: 2.75rem;
  }

  .footer-logo {
    color: var(--color-text-primary);
    display: inline-flex;
    width: fit-content;
  }

  @media (min-width: 48rem) {
    .site-footer__meta {
      align-items: center;
      grid-template-columns: auto minmax(12rem, 1fr) auto auto;
    }

    .site-footer__copyright {
      grid-column: 2;
    }
  }
</style>

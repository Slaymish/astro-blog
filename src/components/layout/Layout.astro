---
// Design System
import "../../design-system/tokens.css";
import "../../design-system/base.css";
import "../../design-system/themes/light.css";
import "../../design-system/themes/dark.css";
import "../../styles/globals.css";

// Layout Components
import Footer from "./Footer.astro";
import Header from "./Header.astro";
import CustomCursor from "../ui/CustomCursor.astro";
import { ClientRouter } from "astro:transitions";
import {
  SITE_AUTHOR,
  SITE_DESCRIPTION,
  SITE_NAME,
  SITE_URL,
  SOCIAL_PROFILES,
  absoluteUrl,
  canonicalFromAstro
} from "../../lib/site";

interface Props {
  title: string;
  description?: string;
  image?: string;
  article?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  author?: string;
  canonicalURL?: string;
  /** Use full-width layout (no max-width constraint on main) */
  fullWidth?: boolean;
}

const { 
  title, 
  description = SITE_DESCRIPTION,
  image = "/apple-touch-icon.png",
  article = false,
  publishedTime,
  modifiedTime,
  tags = [],
  author = SITE_AUTHOR,
  canonicalURL,
  fullWidth = false,
} = Astro.props;

const siteTitle = SITE_NAME;
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const siteURL = Astro.site?.toString() || SITE_URL;
const canonicalHref = canonicalFromAstro(Astro.url, Astro.site, canonicalURL);
const imageURL = absoluteUrl(image, siteURL);
const personId = absoluteUrl("/#person", siteURL);
const websiteId = absoluteUrl("/#website", siteURL);

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": personId,
      "name": SITE_AUTHOR,
      "alternateName": "Slaymish",
      "url": absoluteUrl("/", siteURL),
      "image": absoluteUrl("/apple-touch-icon.png", siteURL),
      "jobTitle": "Software Engineer",
      "sameAs": [...SOCIAL_PROFILES]
    },
    {
      "@type": "WebSite",
      "@id": websiteId,
      "url": absoluteUrl("/", siteURL),
      "name": siteTitle,
      "description": SITE_DESCRIPTION,
      "publisher": { "@id": personId },
      "inLanguage": "en-US"
    },
    article
      ? {
          "@type": "BlogPosting",
          "headline": title,
          "description": description,
          "url": canonicalHref,
          "author": { "@id": personId },
          "publisher": { "@id": personId },
          "image": [imageURL],
          "mainEntityOfPage": {
            "@type": "WebPage",
            "@id": canonicalHref
          },
          ...(publishedTime ? { "datePublished": publishedTime } : {}),
          ...(modifiedTime ? { "dateModified": modifiedTime } : {}),
          ...(tags.length > 0 ? { "keywords": tags.join(", ") } : {})
        }
      : {
          "@type": "WebPage",
          "@id": canonicalHref,
          "url": canonicalHref,
          "name": fullTitle,
          "description": description,
          "isPartOf": { "@id": websiteId },
          "about": { "@id": personId },
          "inLanguage": "en-US"
        }
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Critical inline styles to prevent FOUC - must be first! -->
    <style>
      :root {
        --bg: #faf9f7;
        --surface: #f0ede8;
        --surface-2: #e8e4dd;
        --text: #1a1a1a;
        --text-muted: #6b6560;
        --border: #d6d0c8;
        --border-strong: #b5afa6;
        --accent: #2d6a4f;
        --accent-contrast: #faf9f7;
        --focus: #2d6a4f;
      }

      .dark {
        --bg: #0c0c0c;
        --surface: #1a1917;
        --surface-2: #26251f;
        --text: #e8e4dd;
        --text-muted: #9a948c;
        --border: #3d3a34;
        --border-strong: #524e46;
        --accent: #4ade80;
        --accent-contrast: #0c0c0c;
        --focus: #4ade80;
      }

      /* Apply immediately */
      html {
        background-color: var(--bg);
        color: var(--text);
      }

      body {
        background-color: var(--bg);
        color: var(--text);
        margin: 0;
        padding: 0;
      }
    </style>

    <!-- Critical theme initialization script (must be VERY early to prevent FOUC) -->
    <script is:inline>
      (function applyThemeAndAccent() {
        try {
          var savedTheme = localStorage.getItem('theme') || 'dark';
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var effectiveTheme = savedTheme === 'system' ? (prefersDark ? 'dark' : 'light') : savedTheme;

          document.documentElement.classList.remove('light', 'dark');
          document.documentElement.classList.add(effectiveTheme);
          document.documentElement.setAttribute('data-theme', savedTheme);

          // Default accent is theme-aware: lime green on dark bg passes AA, forest green on light bg passes AA
          var defaultAccent = effectiveTheme === 'dark' ? '#4ade80' : '#2d6a4f';
          var accent = localStorage.getItem('accent') || defaultAccent;
          var accentContrast = localStorage.getItem('accentContrast') || (effectiveTheme === 'dark' ? '#0c0c0c' : '#faf9f7');
          document.documentElement.style.setProperty('--accent', accent);
          document.documentElement.style.setProperty('--focus', accent);
          document.documentElement.style.setProperty('--accent-contrast', accentContrast);
        } catch (e) {
          if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.add('light');
          }
        }
      })();

      // Re-apply after view transitions swap the DOM (theme class lives on <html>
      // which is NOT swapped, but this ensures accent inline style is preserved)
      document.addEventListener('astro:after-swap', function() {
        try {
          var savedTheme = localStorage.getItem('theme') || 'dark';
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var effectiveTheme = savedTheme === 'system' ? (prefersDark ? 'dark' : 'light') : savedTheme;
          document.documentElement.classList.remove('light', 'dark');
          document.documentElement.classList.add(effectiveTheme);
          document.documentElement.setAttribute('data-theme', savedTheme);

          var defaultAccent = effectiveTheme === 'dark' ? '#4ade80' : '#2d6a4f';
          var accent = localStorage.getItem('accent') || defaultAccent;
          var accentContrast = localStorage.getItem('accentContrast') || (effectiveTheme === 'dark' ? '#0c0c0c' : '#faf9f7');
          document.documentElement.style.setProperty('--accent', accent);
          document.documentElement.style.setProperty('--focus', accent);
          document.documentElement.style.setProperty('--accent-contrast', accentContrast);
        } catch (e) {}
      });
    </script>

    <!-- Navigation loading bar — instant feedback on link clicks -->
    <script is:inline>
      (function() {
        var bar = document.getElementById('nav-loading-bar');
        if (!bar) return;

        document.addEventListener('astro:before-preparation', function() {
          bar.classList.remove('done');
          bar.style.width = '0';
          // Force reflow so the width:0 is applied before adding .loading
          void bar.offsetWidth;
          bar.classList.add('loading');
        });

        document.addEventListener('astro:after-swap', function() {
          bar.classList.remove('loading');
          bar.classList.add('done');
        });

        // Clean up after transition finishes
        document.addEventListener('astro:page-load', function() {
          setTimeout(function() {
            bar.classList.remove('done');
            bar.style.width = '0';
          }, 400);
        });
      })();
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Basic Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <link rel="canonical" href={canonicalHref} />
    <link rel="alternate" hreflang="en" href={canonicalHref} />
    <link rel="alternate" hreflang="x-default" href={canonicalHref} />
    
    <!-- Google Fonts - optimized with font-display=swap and reduced weights -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Figtree:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={article ? "article" : "website"} />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:locale" content="en_US" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalHref} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />
    <meta name="twitter:site" content="@Slaymishh" />
    <meta name="twitter:creator" content="@Slaymishh" />
    
    <!-- Article-specific meta tags -->
    {article && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {article && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {article && author && <meta property="article:author" content={author} />}
    {article && tags.map(tag => <meta property="article:tag" content={tag} />)}
    
    <!-- Structured Data for LLMs and Search Engines -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
    
    <!-- Breadcrumb Schema for Homepage -->
    {!article && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [{
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": absoluteUrl("/", siteURL)
          }]
        })} />
    )}
    
    <!-- Additional meta for LLMs -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    
    <!-- Performance and Security -->
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="theme-color" content="#10b981" />
    <meta name="msapplication-TileColor" content="#10b981" />
    
    <!-- Preconnect to external domains for faster loading -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    
    <!-- Favicon and Icons -->
    <link rel="icon" type="image/svg+xml" href="/HB_logo.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    
    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="Hamish's Blog RSS Feed" href="/rss.xml" />
    <link rel="alternate" type="text/plain" title="LLM guidance" href="/llms.txt" />
    
    <!-- View Transitions for SPA-like navigation without full page reloads -->
    <ClientRouter />

    <!-- Analytics — Umami (privacy-respecting, no cookies) -->
    <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="3b77a67f-19f6-4f3c-a7ab-8af0d58bfbc6"></script>

    <!-- KaTeX CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV" crossorigin="anonymous">

    <style is:global>
      *, *::before, *::after {
        box-sizing: border-box;
      }

      html, body {
        overflow-x: clip;
      }

      /* Lenis smooth scroll */
      html.lenis, html.lenis body {
        height: auto;
      }

      .lenis.lenis-smooth {
        scroll-behavior: auto !important;
      }

      .lenis.lenis-smooth [data-lenis-prevent] {
        overscroll-behavior: contain;
      }

      .lenis.lenis-stopped {
        overflow: hidden;
      }

      .lenis.lenis-smooth iframe {
        pointer-events: none;
      }

      /* ── Smoother View Transitions ── */
      @keyframes fade-in {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      @keyframes fade-out {
        from { opacity: 1; transform: translateY(0); }
        to   { opacity: 0; transform: translateY(-4px); }
      }

      ::view-transition-old(root) {
        animation: fade-out 0.3s cubic-bezier(0.22, 1, 0.36, 1) both;
      }

      ::view-transition-new(root) {
        animation: fade-in 0.4s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
      }

      /* Navigation loading bar — shows instantly on click, hides after swap */
      #nav-loading-bar {
        position: fixed;
        top: 0;
        left: 0;
        height: 2px;
        width: 0;
        background: var(--accent);
        z-index: 9999;
        opacity: 0;
        transition: none;
      }

      #nav-loading-bar.loading {
        opacity: 1;
        width: 70%;
        transition: width 8s cubic-bezier(0.1, 0.5, 0.3, 1);
      }

      #nav-loading-bar.done {
        width: 100%;
        transition: width 0.15s ease, opacity 0.3s ease 0.1s;
        opacity: 0;
      }
    </style>
  </head>
  <body class="antialiased min-h-screen flex flex-col" style="background-color: var(--bg); color: var(--text);">
    <div id="nav-loading-bar"></div>
    <CustomCursor />
    <a class="skip-link" href="#main-content">Skip to content</a>

    {article && (
      <div
        id="scroll-progress"
        class="fixed top-0 left-0 h-[3px] bg-[var(--accent)] z-[var(--z-fixed)] transition-none"
        style="width: 0%;"
        role="progressbar"
        aria-label="Reading progress"
        aria-valuenow="0"
        aria-valuemin="0"
        aria-valuemax="100"
      />
    )}

    <Header />
    <div class="w-full px-6 md:px-8 lg:px-10 box-border">
      <main
        id="main-content"
        class={`grow w-full mx-auto py-8 sm:py-12 md:py-16 ${fullWidth ? '' : 'max-w-[var(--content-max-width)]'}`}
        tabindex="-1"
      >
        <slot />
      </main>
      <Footer />
    </div>
    {article && (
      <script is:inline>
        // Scroll progress bar + copy buttons — runs on initial load and after each view transition
        function initArticlePage() {
          var bar = document.getElementById('scroll-progress');
          if (bar) {
            // Remove old listener by replacing with a fresh scroll handler stored on window
            if (window.__scrollHandler) {
              window.removeEventListener('scroll', window.__scrollHandler);
            }
            function updateProgress() {
              var scrollTop = window.scrollY;
              var docHeight = document.documentElement.scrollHeight - window.innerHeight;
              var progress = docHeight > 0 ? Math.min((scrollTop / docHeight) * 100, 100) : 0;
              bar.style.width = progress + '%';
              bar.setAttribute('aria-valuenow', String(Math.round(progress)));
            }
            window.__scrollHandler = updateProgress;
            window.addEventListener('scroll', updateProgress, { passive: true });
            updateProgress();
          }

          // Copy-to-clipboard on code blocks
          document.querySelectorAll('.prose pre').forEach(function(pre) {
            if (pre.querySelector('.code-copy-btn')) return; // already added
            var btn = document.createElement('button');
            btn.className = 'code-copy-btn';
            btn.setAttribute('aria-label', 'Copy code');
            btn.textContent = 'Copy';
            btn.addEventListener('click', function() {
              var code = pre.querySelector('code');
              var text = code ? code.textContent : pre.textContent;
              navigator.clipboard.writeText(text || '').then(function() {
                btn.textContent = 'Copied!';
                setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
              });
            });
            pre.style.position = 'relative';
            pre.appendChild(btn);
          });
        }

        document.addEventListener('astro:page-load', initArticlePage);
      </script>
    )}
    <!-- Custom analytics events for UX success metrics -->
    <script is:inline>
      function initAnalytics() {
        function track(name, data) {
          if (typeof umami !== 'undefined' && umami.track) {
            umami.track(name, data);
          }
        }

        var maxScroll = 0;
        var scrollMilestones = [25, 50, 60, 75, 90, 100];
        var firedMilestones = {};
        var pathname = window.location.pathname;

        if (window.__analyticsScrollHandler) {
          window.removeEventListener('scroll', window.__analyticsScrollHandler);
        }
        function analyticsScroll() {
          var scrollTop = window.scrollY;
          var docHeight = document.documentElement.scrollHeight - window.innerHeight;
          if (docHeight <= 0) return;
          var pct = Math.round((scrollTop / docHeight) * 100);
          if (pct > maxScroll) maxScroll = pct;
          scrollMilestones.forEach(function(m) {
            if (pct >= m && !firedMilestones[m]) {
              firedMilestones[m] = true;
              track('scroll-depth', { depth: m, page: pathname });
            }
          });
        }
        window.__analyticsScrollHandler = analyticsScroll;
        window.addEventListener('scroll', analyticsScroll, { passive: true });

        document.querySelectorAll('a[href*="/cv"], a[href*="cv.pdf"], a[href*="CV"]').forEach(function(el) {
          el.addEventListener('click', function() {
            var label = el.textContent.trim().toLowerCase();
            track(label.includes('download') ? 'cv-download' : 'cv-view', { page: pathname });
          });
        });

        document.querySelectorAll('a[href^="mailto:"]').forEach(function(el) {
          el.addEventListener('click', function() { track('email-click', { page: pathname }); });
        });

        document.querySelectorAll('.share-link, a[href*="twitter.com/intent"], a[href*="linkedin.com/share"]').forEach(function(el) {
          el.addEventListener('click', function() {
            var href = el.getAttribute('href') || '';
            var platform = href.includes('twitter.com') || href.includes('x.com') ? 'twitter' : href.includes('linkedin.com') ? 'linkedin' : 'unknown';
            track('social-share', { platform: platform, page: pathname });
          });
        });

        document.querySelectorAll('a[target="_blank"], a[rel*="noopener"]').forEach(function(el) {
          el.addEventListener('click', function() {
            var href = el.getAttribute('href') || '';
            if (href.includes('github.com')) track('outbound-click', { destination: 'github', page: pathname });
            else if (href.includes('linkedin.com')) track('outbound-click', { destination: 'linkedin', page: pathname });
          });
        });

        document.querySelectorAll('.cta-primary, a[href="/projects"], a[href="/writing"]').forEach(function(el) {
          if (el.closest('nav') || el.closest('header') || el.closest('footer')) return;
          el.addEventListener('click', function() { track('cta-click', { text: el.textContent.trim(), page: pathname }); });
        });

        var pageStart = Date.now();
        document.addEventListener('visibilitychange', function onHide() {
          if (document.visibilityState === 'hidden') {
            track('scroll-depth-final', { depth: maxScroll, page: pathname });
            track('time-on-page', { seconds: Math.round((Date.now() - pageStart) / 1000), page: pathname });
          }
        });
      }

      document.addEventListener('astro:page-load', initAnalytics);
    </script>
    <!-- Lenis smooth scroll -->
    <script>
      import Lenis from 'lenis';

      let lenis: Lenis | null = null;

      function initLenis() {
        // Destroy previous instance
        if (lenis) {
          lenis.destroy();
          lenis = null;
        }

        // Skip on touch-primary devices. Lenis attaches touch listeners that
        // can randomly block native scroll on mobile — native momentum scroll
        // is faster and more reliable on phones/tablets anyway.
        if (window.matchMedia('(pointer: coarse)').matches) return;

        // Respect reduced-motion preference
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          // Lenis 1.x leaves touch scrolling native by default (no smooth
          // interpolation on touchscreen), so no extra option is needed.
        });

        function raf(time: number) {
          lenis?.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
      }

      document.addEventListener('astro:page-load', initLenis);
    </script>
  </body>
</html>

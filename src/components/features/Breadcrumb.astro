---
import { SITE_URL, absoluteUrl } from "../../lib/site";

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-8">
  <ol class="flex items-center flex-wrap gap-x-2 gap-y-1 text-sm text-[var(--text-muted)]" role="list">
    <li role="listitem">
      <a
        href="/"
        class="text-[var(--accent)] hover:underline no-underline border-b-0"
      >
        Home
      </a>
    </li>
    {items.map((item, index) => (
      <li role="listitem" class="flex items-center gap-2">
        <span class="text-[var(--border-strong)] select-none">/</span>
        {index === items.length - 1 ? (
          <span class="text-[var(--text)]" aria-current="page">
            {item.name}
          </span>
        ) : (
          <a
            href={item.url}
            class="text-[var(--accent)] hover:underline no-underline border-b-0"
          >
            {item.name}
          </a>
        )}
      </li>
    ))}
  </ol>
</nav>

<!-- Structured Data for Breadcrumbs -->
<script type="application/ld+json" is:inline set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": absoluteUrl("/", SITE_URL)
    },
    ...items.map((item, index) => ({
      "@type": "ListItem",
      "position": index + 2,
      "name": item.name,
      "item": absoluteUrl(item.url, SITE_URL)
    }))
  ]
})} />

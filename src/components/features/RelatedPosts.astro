---
import { fetchSanity } from "../../lib/sanity";

interface Props {
  currentPostSlug: string;
  currentPostTags: string[];
  limit?: number;
}

const { currentPostSlug, currentPostTags, limit = 3 } = Astro.props;

let relatedPosts: Array<{ title: string; slug: string; publishedAt: string }> = [];

if (currentPostTags.length > 0) {
  relatedPosts = await fetchSanity(`
    *[_type == "post" && slug.current != $slug && count(tags[@ in $tags]) > 0]
      | order(publishedAt desc)[0...$limit]{
        title,
        "slug": slug.current,
        publishedAt
      }
  `, {
    slug: currentPostSlug,
    tags: currentPostTags,
    limit
  });
}
---

{relatedPosts.length > 0 && (
  <div
    class="rounded-[var(--radius-lg)] p-6 border border-[var(--border)] bg-[var(--surface)]"
    itemscope
    itemtype="https://schema.org/Article"
  >
    <h2 class="text-xl font-semibold mb-4 text-[var(--text)]" itemprop="headline">
      Related Posts
    </h2>
    <div class="space-y-4" itemprop="articleBody">
      {relatedPosts.map((post: any) => (
        <article
          class="border-l-2 border-[var(--accent)] pl-4 py-2"
          itemscope
          itemtype="https://schema.org/BlogPosting"
        >
          <h3 class="font-medium" itemprop="headline">
            <a
              href={`/posts/${post.slug}`}
              class="text-[var(--text)] no-underline border-b-0 hover:text-[var(--accent)] hover:opacity-100 transition-colors duration-200"
              itemprop="url"
            >
              {post.title}
            </a>
          </h3>
          <time
            datetime={new Date(post.publishedAt).toISOString()}
            class="text-sm text-[var(--text-muted)] block mt-1"
            itemprop="datePublished"
          >
            {new Date(post.publishedAt).toLocaleDateString()}
          </time>
        </article>
      ))}
    </div>
  </div>
)}

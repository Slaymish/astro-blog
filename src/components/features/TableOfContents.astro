---
interface TocItem {
  id: string;
  text: string;
  level: number;
}

interface Props {
  content: string;
  htmlContent?: string;
  minItems?: number;
}

const { content, htmlContent, minItems = 3 } = Astro.props;

const entityMap: Record<string, string> = {
  '&lt;': '<',
  '&gt;': '>',
  '&amp;': '&',
  '&quot;': '"',
  '&#39;': "'",
  '&apos;': "'",
  '&nbsp;': ' ',
};

function decodeEntities(str: string): string {
  return str.replace(/&(?:lt|gt|amp|quot|#39|apos|nbsp);/g, match => entityMap[match] || match);
}

function extractTableOfContents(markdown: string, html?: string): TocItem[] {
  const toc: TocItem[] = [];

  if (html) {
    const headingRegex = /<h([2-4])[^>]*id="([^"]*)"[^>]*>(.*?)<\/h[2-4]>/gi;
    let match;
    while ((match = headingRegex.exec(html)) !== null) {
      const level = parseInt(match[1]);
      const id = match[2];
      const rawText = match[3];
      const text = decodeEntities(rawText.replace(/<[^>]*>/g, '')).trim();
      if (level >= 2 && level <= 4 && id && text) {
        toc.push({ id, text, level });
      }
    }
  } else {
    const headingRegex = /^(#{2,4})\s+(.+)$/gm;
    let match;
    while ((match = headingRegex.exec(markdown)) !== null) {
      const level = match[1].length;
      const rawText = match[2];
      const text = rawText
        .replace(/\*\*([^*]+)\*\*/g, '$1')
        .replace(/\*([^*]+)\*/g, '$1')
        .replace(/`([^`]+)`/g, '$1')
        .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
        .trim();
      const id = text
        .toLowerCase()
        .replace(/\s+/g, '-')
        .replace(/[^\w-]/g, '')
        .replace(/-{2,}/g, '-')
        .replace(/^-|-$/g, '');
      if (level >= 2 && level <= 4 && id) {
        toc.push({ id, text, level });
      }
    }
  }

  return toc;
}

const toc = extractTableOfContents(content, htmlContent);
const shouldShowToc = toc.length >= minItems;
---

{shouldShowToc && (
  <aside
    class="mb-8 rounded-[var(--radius-lg)] p-6 border-l-[3px] border-[var(--accent)] bg-[var(--surface-2)]"
    aria-label="Table of contents"
  >
    <h2 class="text-lg font-semibold mb-4 text-[var(--text)]">
      Table of Contents
    </h2>
    <nav aria-label="Article sections">
      <ol class="space-y-2" role="list">
        {toc.map((item) => (
          <li
            role="listitem"
            class={`text-sm ${item.level === 2 ? 'ml-0' : item.level === 3 ? 'ml-4' : 'ml-8'}`}
          >
            <a
              href={`#${item.id}`}
              class="text-[var(--accent)] hover:underline no-underline border-b-0 block py-1"
            >
              {item.text}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  </aside>
)}

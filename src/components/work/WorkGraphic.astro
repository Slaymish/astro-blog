---
import type { GraphicKind } from '../../lib/work';

interface Props {
  kind: GraphicKind;
  alt: string;
  compact?: boolean;
  priority?: boolean;
}

const { kind, alt, compact = false, priority = false } = Astro.props;

const images: Partial<Record<GraphicKind, { src: string; position?: string }>> = {
  brontehf: {
    src: '/images/work/bronte-projects.webp',
  },
  'you-inc': {
    src: '/images/work/youinc-demo-dashboard.png',
  },
  'health-agent': {
    src: '/images/posts/status_screenshot.png',
    position: 'top center',
  },
};

const image = images[kind];
const graphicAlt = kind === 'brontehf'
  ? 'BrontëHF’s public projects page showing a filterable grid of portfolio work.'
  : kind === 'you-inc'
    ? 'The working YouInc demo dashboard showing a cashflow waterfall, operating statement, expense and income breakdowns, and recurring subscriptions using sample data.'
  : alt;
---

<div
  class:list={['work-graphic', `work-graphic--${kind}`, compact && 'work-graphic--compact']}
  role="img"
  aria-label={graphicAlt}
>
  {(kind === 'brontehf' || kind === 'you-inc') && image && (
    <img
      src={image.src}
      alt=""
      width={kind === 'you-inc' ? '2462' : '2550'}
      height={kind === 'you-inc' ? '1420' : '1231'}
      loading={priority ? 'eager' : 'lazy'}
      fetchpriority={priority ? 'high' : 'auto'}
      decoding="async"
    />
  )}

  {kind === 'gpu-share' && (
    <div class="work-graphic__gpu">
      <div class="work-graphic__gpu-public">
        <small>Public cloud</small>
        <strong>Accounts · billing · cache</strong>
      </div>
      <div class="work-graphic__gpu-tunnel"><span>Encrypted tunnel</span><b>→</b></div>
      <div class="work-graphic__gpu-private">
        <small>Private host</small>
        <strong>Ollama · Blender · RTX GPU</strong>
      </div>
      <p>One explicit trust boundary.</p>
    </div>
  )}

  {kind === 'health-agent' && image && (
    <>
      <img src={image.src} alt="" loading="lazy" decoding="async" style={`object-position: ${image.position};`} />
      <div class="work-graphic__pipeline">
        <span>Apple Health</span><b>→</b><span>Postgres</span><b>→</b><span>Trends</span>
      </div>
    </>
  )}

  {kind === 'home-lab' && (
    <div class="work-graphic__architecture">
      <div><small>Public</small><strong>Cloudflare</strong></div>
      <b>→</b>
      <div class="work-graphic__pi"><small>8GB · 1TB</small><strong>Raspberry Pi</strong></div>
      <b>→</b>
      <div><small>Encrypted</small><strong>B2 backup</strong></div>
      <p><span>Restore tested</span><strong>1h 45m</strong></p>
    </div>
  )}

  {kind === 'wildfire' && (
    <div class="work-graphic__experiment">
      <div class="work-graphic__experiment-head"><span>PySpark experiment</span><strong>1.88M records</strong></div>
      <div class="work-graphic__matrix" aria-hidden="true">
        {Array.from({ length: 28 }).map((_, index) => <i style={`--value: ${(index * 17) % 100}%`}></i>)}
      </div>
      <div class="work-graphic__tradeoff"><span>Rare-event recall ↑</span><span>False positives ↑</span></div>
    </div>
  )}
</div>

<style>
  .work-graphic {
    aspect-ratio: 16 / 10;
    background: var(--color-bg-inset);
    border: 1px solid var(--color-stroke-subtle);
    color: var(--color-text-primary);
    max-height: clamp(22rem, 40vw, 34rem);
    overflow: hidden;
    position: relative;
  }

  .work-graphic img {
    border-radius: 0;
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .work-graphic--health-agent img {
    box-sizing: border-box;
    object-fit: contain;
    padding: clamp(1rem, 3vw, 2rem);
  }

  .work-graphic__boundary,
  .work-graphic__pipeline {
    backdrop-filter: blur(12px);
    background: rgb(7 9 8 / 88%);
    border: 1px solid var(--color-stroke-strong);
    display: flex;
    font-size: var(--type-label);
    gap: var(--spacing-3);
    left: var(--spacing-4);
    padding: var(--spacing-3) var(--spacing-4);
    position: absolute;
  }

  .work-graphic__boundary,
  .work-graphic__pipeline { bottom: var(--spacing-4); justify-content: space-between; right: var(--spacing-4); }
  .work-graphic__boundary b { color: var(--color-action); font-weight: var(--font-weight-medium); }
  .work-graphic__pipeline b { color: var(--color-action); }

  .work-graphic--gpu-share {
    background-color: #080b0a;
    background-image: linear-gradient(var(--color-stroke-subtle) 1px, transparent 1px), linear-gradient(90deg, var(--color-stroke-subtle) 1px, transparent 1px);
    background-position: center;
    background-size: clamp(1.5rem, 4vw, 2.5rem) clamp(1.5rem, 4vw, 2.5rem);
    padding: clamp(1rem, 4vw, 3rem);
  }
  .work-graphic__gpu { align-content: center; display: grid; gap: clamp(.5rem, 2vw, 1.25rem); grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr); height: 100%; position: relative; }
  .work-graphic__gpu-public,
  .work-graphic__gpu-private { border: 1px solid var(--color-stroke-strong); display: flex; flex-direction: column; gap: var(--spacing-2); min-width: 0; padding: clamp(.75rem, 2.5vw, 2rem); }
  .work-graphic__gpu-private { border-color: var(--color-action); }
  .work-graphic__gpu small { color: var(--color-text-secondary); font-size: clamp(.5rem, 1vw, .7rem); letter-spacing: .08em; text-transform: uppercase; }
  .work-graphic__gpu strong { font-size: clamp(.65rem, 1.5vw, 1rem); line-height: 1.35; }
  .work-graphic__gpu-tunnel { align-items: center; color: var(--color-action); display: flex; flex-direction: column; font-size: clamp(.6rem, 1vw, .75rem); text-align: center; text-transform: uppercase; }
  .work-graphic__gpu-tunnel b { font-size: clamp(1rem, 2.5vw, 2rem); }
  .work-graphic__gpu p { bottom: clamp(.35rem, 1.2vw, .8rem); color: var(--color-text-secondary); font-size: clamp(.55rem, 1.2vw, .8rem); grid-column: 1 / -1; line-height: 1.4; margin: 0; position: absolute; }

  .work-graphic--you-inc { aspect-ratio: 2462 / 1420; }

  .work-graphic--home-lab {
    background-color: #111713;
    background-image: linear-gradient(var(--color-stroke-subtle) 1px, transparent 1px), linear-gradient(90deg, var(--color-stroke-subtle) 1px, transparent 1px);
    background-position: center;
    background-size: clamp(1.5rem, 4vw, 2.5rem) clamp(1.5rem, 4vw, 2.5rem);
    padding: clamp(1rem, 4vw, 3rem);
  }
  .work-graphic__architecture { align-items: center; display: grid; gap: clamp(.3rem, 2vw, 1rem); grid-template-columns: 1fr auto 1.2fr auto 1fr; height: 100%; text-align: center; }
  .work-graphic__architecture div { border: 1px solid var(--color-stroke-strong); display: flex; flex-direction: column; padding: clamp(.65rem, 2vw, 1.5rem) .4rem; }
  .work-graphic__architecture small { color: var(--color-text-secondary); font-size: clamp(.5rem, 1vw, .7rem); text-transform: uppercase; }
  .work-graphic__architecture strong { font-size: clamp(.65rem, 1.5vw, 1rem); }
  .work-graphic__architecture > b { color: var(--color-action); }
  .work-graphic__architecture .work-graphic__pi { border-color: var(--color-action); }
  .work-graphic__architecture p { align-items: center; bottom: clamp(.75rem, 2vw, 1.5rem); display: flex; font-size: clamp(.6rem, 1.2vw, .8rem); justify-content: space-between; left: clamp(1rem, 4vw, 3rem); margin: 0; position: absolute; right: clamp(1rem, 4vw, 3rem); }
  .work-graphic__architecture p span { color: var(--color-text-secondary); text-transform: uppercase; }
  .work-graphic__architecture p strong { color: var(--color-action); }

  .work-graphic--wildfire { background: #efece4; color: #111713; padding: clamp(1rem, 4vw, 3rem); }
  .work-graphic__experiment { display: flex; flex-direction: column; height: 100%; }
  .work-graphic__experiment-head { align-items: start; display: flex; font-size: clamp(.65rem, 1.5vw, 1rem); justify-content: space-between; text-transform: uppercase; }
  .work-graphic__experiment-head strong { font-family: var(--font-display); font-size: clamp(1rem, 2.8vw, 2rem); }
  .work-graphic__matrix { display: grid; flex: 1; gap: 3px; grid-template-columns: repeat(7, 1fr); margin-block: clamp(.75rem, 2vw, 1.5rem); }
  .work-graphic__matrix i { background: color-mix(in srgb, #24583e var(--value), #d8ddd6); }
  .work-graphic__tradeoff { display: flex; font-size: clamp(.55rem, 1.2vw, .75rem); font-weight: 700; justify-content: space-between; text-transform: uppercase; }
  .work-graphic__tradeoff span:last-child { color: #a83225; }

  .work-graphic--compact .work-graphic__pipeline { font-size: .6rem; }

  @media (max-width: 30rem) {
    .work-graphic__pipeline b { display: none; }
  }
</style>

---
interface Props {
  class?: string;
  size?: number;
}

const { class: className = '', size = 36 } = Astro.props;

const path1 = "M165.21,401.63l23.71-142.95c2.72-16.41,16.92-28.45,33.56-28.45h72.85c16.64,0,30.84-12.04,33.56-28.45l22.02-132.82c2.99-18.02-8.79-35.18-26.68-38.88l-42.96-8.87c-18.91-3.91-37.28,8.7-40.44,27.75l-23.25,140.23c-.68,4.08-4.21,7.08-8.35,7.08h0c-5.22,0-9.2-4.69-8.35-9.84l16.17-97.51c3.83-23.06-16.21-43.02-39.26-39.1l-45.72,7.77c-14.3,2.43-25.48,13.66-27.85,27.97l-49.29,297.17c-3.04,18.35,9.22,35.74,27.52,39.04l43.14,7.77c18.67,3.37,36.49-9.19,39.59-27.91Z";
const path2 = "M223.78,427.65l112.72-19.17c14.3-2.43,25.48-13.66,27.85-27.97l15.54-93.7c3.44-20.73-12.55-39.58-33.56-39.58h-123.96c-8.32,0-15.42,6.02-16.78,14.22l-21.08,127.09c-3.82,23.06,16.21,43.02,39.26,39.1Z";
---

<span
  class:list={['hb-logo-wrap', className]}
  style={`width: ${size}px; height: ${size}px;`}
  aria-hidden="true"
>
  <svg class="logo-svg logo-main" viewBox="0 0 453.54 453.54" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
    <path d={path1}/>
    <path d={path2}/>
  </svg>
  <svg class="logo-svg logo-glitch glitch-r" viewBox="0 0 453.54 453.54" fill="#ff3d3d" xmlns="http://www.w3.org/2000/svg">
    <path d={path1}/><path d={path2}/>
  </svg>
  <svg class="logo-svg logo-glitch glitch-c" viewBox="0 0 453.54 453.54" fill="#3dd8ff" xmlns="http://www.w3.org/2000/svg">
    <path d={path1}/><path d={path2}/>
  </svg>
</span>

<style>
  /* ── Container ── */
  .hb-logo-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
    position: relative;
  }

  /* ── Shared SVG layer ── */
  .logo-svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Glitch layers sit on top */
  .logo-glitch {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    pointer-events: none;
  }

  /* ── Elastic Pop Entry ── */
  .hb-logo-wrap {
    opacity: 0;
    transform: scale(0) rotate(-8deg);
    transform-origin: center center;
  }

  .hb-logo-wrap.animate-in {
    animation: hb-bounce-in 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes hb-bounce-in {
    0% {
      opacity: 0;
      transform: scale(0) rotate(-8deg);
    }
    100% {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }
  }

  /* ── Glitch Hover — enter ── */
  .hb-logo-wrap.glitch-active .logo-main {
    animation: hb-glitch-main-in 0.5s ease forwards;
  }

  .hb-logo-wrap.glitch-active .glitch-r {
    animation: hb-glitch-r 0.5s steps(4) forwards;
  }

  .hb-logo-wrap.glitch-active .glitch-c {
    animation: hb-glitch-c 0.5s steps(4) forwards;
  }

  /* ── Glitch Hover — leave ── */
  .hb-logo-wrap.glitch-out .logo-main {
    animation: hb-glitch-main-out 0.4s ease forwards;
  }

  .hb-logo-wrap.glitch-out .glitch-r {
    animation: hb-glitch-r-out 0.4s steps(5) forwards;
  }

  .hb-logo-wrap.glitch-out .glitch-c {
    animation: hb-glitch-c-out 0.4s steps(5) forwards;
  }

  /* ── Keyframes ── */
  @keyframes hb-glitch-main-in {
    0%   { transform: translateX(0); }
    20%  { transform: translateX(4px) skewX(-2deg); }
    40%  { transform: translateX(-3px) skewX(1.5deg); }
    60%  { transform: translateX(2px) skewX(-0.5deg); }
    80%  { transform: translateX(-1px) skewX(0deg); }
    100% { transform: translateX(0); }
  }

  @keyframes hb-glitch-main-out {
    0%   { transform: translateX(0); }
    25%  { transform: translateX(-3px) skewX(2deg); }
    50%  { transform: translateX(2px) skewX(-1deg); }
    75%  { transform: translateX(-1px) skewX(0deg); }
    100% { transform: translateX(0); }
  }

  @keyframes hb-glitch-r {
    0%   { opacity: 0.7; transform: translate(-5px, -2px); }
    25%  { opacity: 0.5; transform: translate(3px, 1px); }
    50%  { opacity: 0.3; transform: translate(-2px, 2px); }
    75%  { opacity: 0.1; transform: translate(1px, -1px); }
    100% { opacity: 0;   transform: translate(0); }
  }

  @keyframes hb-glitch-c {
    0%   { opacity: 0.7; transform: translate(4px, 2px); }
    25%  { opacity: 0.5; transform: translate(-3px, -1px); }
    50%  { opacity: 0.3; transform: translate(2px, -2px); }
    75%  { opacity: 0.1; transform: translate(-1px, 1px); }
    100% { opacity: 0;   transform: translate(0); }
  }

  @keyframes hb-glitch-r-out {
    0%   { opacity: 0; }
    20%  { opacity: 0.5; transform: translate(4px, -2px); }
    40%  { opacity: 0.3; transform: translate(-3px, 2px); }
    60%  { opacity: 0.4; transform: translate(5px, -1px); }
    80%  { opacity: 0.15; transform: translate(-2px, 1px); }
    100% { opacity: 0; }
  }

  @keyframes hb-glitch-c-out {
    0%   { opacity: 0; }
    20%  { opacity: 0.5; transform: translate(-3px, 2px); }
    40%  { opacity: 0.3; transform: translate(4px, -1px); }
    60%  { opacity: 0.4; transform: translate(-5px, 1px); }
    80%  { opacity: 0.15; transform: translate(2px, -1px); }
    100% { opacity: 0; }
  }
</style>

<script>
  function initLogoAnim() {
    const wraps = document.querySelectorAll<HTMLElement>('.hb-logo-wrap');
    wraps.forEach((el) => {
      // Entry pop
      setTimeout(() => {
        el.classList.add('animate-in');
      }, 200);

      // Glitch on hover
      let glitchTimeout: ReturnType<typeof setTimeout> | null = null;

      el.addEventListener('mouseenter', () => {
        if (glitchTimeout) clearTimeout(glitchTimeout);
        el.classList.remove('glitch-out');
        void el.offsetWidth;
        el.classList.add('glitch-active');
      });

      el.addEventListener('mouseleave', () => {
        el.classList.remove('glitch-active');
        void el.offsetWidth;
        el.classList.add('glitch-out');
        glitchTimeout = setTimeout(() => {
          el.classList.remove('glitch-out');
        }, 450);
      });
    });
  }

  // Run on initial load and after Astro view transitions
  document.addEventListener('astro:page-load', initLogoAnim);
  // Fallback for non-transition navigation
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLogoAnim);
  } else {
    initLogoAnim();
  }
</script>

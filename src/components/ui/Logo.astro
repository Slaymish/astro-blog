---
interface Props {
  class?: string;
  size?: number;
}

const { class: className = '', size = 36 } = Astro.props;
---

<span
  class:list={['nav-logo-icon', className]}
  style={`width: ${size}px; height: ${size}px;`}
  aria-hidden="true"
/>

<style>
  .nav-logo-icon {
    display: inline-block;
    background-color: currentColor;
    mask-image: url('/HB_logo.svg');
    mask-size: contain;
    mask-repeat: no-repeat;
    mask-position: center;
    -webkit-mask-image: url('/HB_logo.svg');
    -webkit-mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-position: center;
  }
</style>

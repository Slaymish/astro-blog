---
import Layout from '../components/layout/Layout.astro';
import ButtonLink from '../components/ui/ButtonLink.astro';
import { CONTACT_EMAIL, SITE_URL, absoluteUrl } from '../lib/site';
---

<Layout
  title="CV — Hamish Burke"
  description="Current professional summary and academic CV for Hamish Burke, a software engineer in Wellington, New Zealand."
  canonicalURL={absoluteUrl('/cv', SITE_URL)}
>
  <article class="cv">
    <header class="cv__hero">
      <p class="cv__eyebrow">Curriculum vitae</p>
      <h1>Software engineer.<br />Systems thinker.</h1>
      <p>
        I work across digital products, AI systems, infrastructure, and the interfaces that make them usable.
        I’m currently a web developer at Alphero and take on selected independent projects.
      </p>
      <div class="cv__actions">
        <ButtonLink href="https://www.linkedin.com/in/hamish-burke-2301669a" external>Current experience on LinkedIn</ButtonLink>
        <ButtonLink href="/work" variant="secondary">Selected work</ButtonLink>
      </div>
    </header>

    <section class="cv__facts" aria-label="Professional summary">
      <div><span>Current role</span><strong>Web Developer · Alphero</strong></div>
      <div><span>Education</span><strong>MSc Computer Science · Victoria University of Wellington</strong></div>
      <div><span>Based in</span><strong>Wellington, New Zealand</strong></div>
      <div><span>Focus</span><strong>Digital products · AI automation · technical systems</strong></div>
    </section>

    <section class="cv__academic" aria-labelledby="academic-cv-heading">
      <div>
        <p class="cv__eyebrow">Document archive</p>
        <h2 id="academic-cv-heading">Academic CV</h2>
      </div>
      <div>
        <p>
          The downloadable PDF is an earlier academic snapshot. It predates my current Alphero role and
          still describes the MSc as in progress. Use LinkedIn and this site for current professional context.
        </p>
        <div class="cv__actions">
          <ButtonLink href="/cv.pdf" variant="secondary">Open academic CV</ButtonLink>
          <a href={`mailto:${CONTACT_EMAIL}`}>Request a current CV →</a>
        </div>
      </div>
    </section>
  </article>
</Layout>

<style>
  .cv__hero { padding-block: var(--hero-top-space) var(--hero-bottom-space); }
  .cv__eyebrow { color: var(--color-action); font-size: var(--type-label); font-weight: 700; letter-spacing: .1em; margin: 0 0 var(--spacing-5); text-transform: uppercase; }
  .cv__hero h1 { font-size: var(--type-display); letter-spacing: -.065em; line-height: .88; margin: 0; }
  .cv__hero > p:not(.cv__eyebrow) { color: var(--color-text-secondary); font-size: clamp(1.15rem, 2.2vw, 1.5rem); line-height: 1.5; max-width: 43rem; }
  .cv__actions { align-items: center; display: flex; flex-wrap: wrap; gap: var(--spacing-3) var(--spacing-5); margin-top: var(--spacing-8); }
  .cv__facts { border-top: 1px solid var(--color-stroke-subtle); }
  .cv__facts > div { border-bottom: 1px solid var(--color-stroke-subtle); display: grid; gap: var(--spacing-3); padding-block: clamp(1.4rem, 4vw, 2.5rem); }
  .cv__facts span { color: var(--color-action); font-size: var(--type-label); font-weight: 700; letter-spacing: .08em; text-transform: uppercase; }
  .cv__facts strong { font-size: clamp(1.05rem, 2vw, 1.35rem); font-weight: 600; }
  .cv__academic { display: grid; gap: var(--spacing-8); margin-block: clamp(5rem, 12vw, 10rem); }
  .cv__academic h2 { font-size: clamp(2.5rem, 6vw, 5rem); letter-spacing: -.055em; margin: 0; }
  .cv__academic div > p:not(.cv__eyebrow) { color: var(--color-text-secondary); font-size: clamp(1.05rem, 1.5vw, 1.2rem); line-height: 1.7; max-width: 42rem; }
  .cv__academic .cv__actions > a:last-child { color: var(--color-text-primary); font-size: var(--type-body-small); font-weight: 700; min-height: 2.75rem; }
  @media (min-width: 48rem) {
    .cv__facts > div { grid-template-columns: minmax(9rem, .4fr) minmax(0, 1.6fr); }
    .cv__academic { grid-template-columns: minmax(12rem, .6fr) minmax(0, 1.4fr); }
  }
</style>

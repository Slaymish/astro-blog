---
import Layout from "../components/layout/Layout.astro";
import GridTile from "../components/ui/GridTile.astro";
import { fetchSanity, urlFor } from "../lib/sanity";

export const prerender = false;

type ProjectDoc = {
  title: string;
  description?: string;
  slug: string;
  date: string;
  technologies?: string[];
  homeTileSize?: 'square' | 'wide';
  relatedPostSlug?: string;
  link?: string;
};

type PostDoc = {
  title: string;
  excerpt?: string;
  slug: string;
  publishedAt: string;
  tags?: string[];
};

type ReportDoc = {
  title: string;
  description?: string;
  slug: string;
  publishedAt: string;
  tags?: string[];
};

type ReadingItem = {
  title: string;
  author: string;
  status: 'reading' | 'read' | 'to-read';
  coverImage?: any;
  link?: string;
};

const projects = await fetchSanity<ProjectDoc[]>(`
  *[_type == "project"] | order(date desc)[0...8]{
    title,
    description,
    "slug": slug.current,
    date,
    technologies,
    homeTileSize,
    link,
    "relatedPostSlug": relatedPost->slug.current
  }
`);

const posts = await fetchSanity<PostDoc[]>(`
  *[_type == "post"] | order(publishedAt desc)[0...6]{
    title,
    excerpt,
    "slug": slug.current,
    publishedAt,
    tags
  }
`);

const reports = await fetchSanity<ReportDoc[]>(`
  *[_type == "report"] | order(publishedAt desc)[0...6]{
    title,
    description,
    "slug": slug.current,
    publishedAt,
    tags
  }
`);

const readingItems = await fetchSanity<ReadingItem[]>(`
  *[_type == "book" && status == "reading"] | order(title asc)[0...2]{
    title,
    author,
    status,
    coverImage,
    link
  }
`);

const homeDescription = "Welcome to my personal site - a collection of projects, writing, and thoughts.";

const displayPosts = [
  ...posts.map(p => ({ ...p, _type: 'post' as const })),
  ...reports.map(r => ({ ...r, excerpt: r.description, _type: 'report' as const }))
].sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime());

const liveTools = projects.filter(p => p.link);

const projectTiles = projects.map((project) => {
  const dateStr = new Date(project.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
  // Live tools link directly to the tool; otherwise link to write-up or project page
  const linksToOwnPage = !project.link && !project.relatedPostSlug;
  const href = project.link
    ? project.link
    : project.relatedPostSlug
      ? `/posts/${project.relatedPostSlug}`
      : `/projects/${project.slug}`;
  return {
    title: project.title,
    description: project.description,
    href,
    size: project.homeTileSize === 'wide' ? 'wide' : 'square',
    tags: project.technologies || [],
    date: dateStr,
    type: project.link ? 'tool' as const : 'project' as const,
    external: !!project.link,
    // Only set transition name when the tile links to its own detail page
    // (title won't match if linking to a related post with a different title)
    transitionName: linksToOwnPage ? `title-projects-${project.slug}` : undefined,
  };
});

const postTiles = displayPosts.map((post) => {
  const dateStr = new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
  const slug = post.slug;
  const prefix = post._type === 'report' ? 'reports' : 'posts';
  return {
    title: post.title,
    description: post.excerpt || '',
    href: `/${prefix}/${slug}`,
    size: 'square',
    tags: post.tags || [],
    date: dateStr,
    type: post._type,
    transitionName: `title-${prefix}-${slug}`,
  };
});

const readingPreview = readingItems.slice(0, 2);
---

<Layout title="Hamish Burke" description={homeDescription}>

  <!-- Masthead -->
  <section class="py-12 md:py-16 text-center">
    <div class="max-w-[40rem] mx-auto">
      <h1 class="font-serif text-[clamp(3.5rem,9vw,5rem)] font-bold tracking-[-0.03em] text-[var(--text)] mb-6">
        Hi, I'm Hamish
      </h1>
      <p class="text-lg text-[var(--text-muted)] leading-[1.7] mb-4">
        Software engineer building AI infrastructure, self-hosted tools, and full-stack web applications.
        Based in Wellington, NZ. Junior Web Developer at <a href="https://www.alphero.com/" target="_blank" rel="noopener noreferrer" class="text-[var(--text-muted)] no-underline hover:text-[var(--accent)] hover:opacity-100 transition-colors">Alphero</a>.
      </p>
      <p class="text-base text-[var(--text-muted)] leading-[1.7] mb-8 opacity-80">
        I write about what I learn along the way.
      </p>
      <div class="flex flex-wrap justify-center gap-4 mb-6">
        <a
          href="/tools"
          class="cta-primary text-base text-[var(--accent)] py-3 px-6 rounded-[var(--radius-base)] no-underline border border-[var(--accent)] font-medium transition-colors"
        >
          Try my tools
        </a>
        <a
          href="/projects"
          class="text-base text-[var(--text)] py-3 px-6 rounded-[var(--radius-base)] no-underline border border-[var(--border)] font-medium transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)]"
        >
          See my projects
        </a>
        <a
          href="/writing"
          class="text-base text-[var(--text)] py-3 px-6 rounded-[var(--radius-base)] no-underline border border-[var(--border)] font-medium transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)]"
        >
          Read my writing
        </a>
      </div>
      <p class="text-sm text-[var(--text-muted)] opacity-70">
        Currently: Junior Web Developer at <a href="https://www.alphero.com/" target="_blank" rel="noopener noreferrer" class="text-[var(--text-muted)] no-underline hover:text-[var(--accent)] hover:opacity-100 transition-colors">Alphero</a> &middot; MSc Computer Science, VUW
      </p>
    </div>
  </section>

  <!-- Bento Grid -->
  <section class="mb-8 w-full sm:w-[90vw] sm:ml-[calc(50%-45vw)]">
    <div class="grid grid-cols-1 gap-3 sm:grid-flow-row-dense sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-3">

      {postTiles.slice(0, 2).map(tile => <GridTile {...tile} />)}
      {projectTiles.filter(t => t.type !== 'tool').slice(0, 3).map(tile => <GridTile {...tile} />)}

      <!-- Bouldering hobby tile -->
      <div class="aspect-square px-1 pb-2">
        <div
          class="tile-image group relative h-full w-full overflow-hidden rounded-[var(--radius-md)] bg-[var(--surface)]"
          style={`--tile-image: url('/images/tiles/bouldering.JPEG'); --tile-image-overlay: linear-gradient(180deg, rgba(10, 10, 10, 0.15), rgba(10, 10, 10, 0.55))`}
        >
          <div class="flex items-center justify-between pl-4 pr-2 pt-2 text-sm tracking-tight text-[var(--tile-image-text,var(--text-muted))]">
            <span class="py-1.5">Hobby</span>
          </div>
          <div class="p-5">
            <div class="font-serif font-semibold text-xl mb-2 text-[var(--tile-image-text,var(--text))] flex items-center justify-between gap-2">
              <span>Bouldering</span>
            </div>
            <div class="hobby-list text-sm text-[var(--tile-image-text,var(--text-muted))]">
              <div><span class="label">Currently:</span> 4/5 Projects (Faultline levels)</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Piano hobby tile -->
      <div class="aspect-square px-1 pb-2">
        <div
          class="tile-image group relative h-full w-full overflow-hidden rounded-[var(--radius-md)] bg-[var(--surface)]"
          style={`--tile-image: url('/images/tiles/piano.jpg'); --tile-image-overlay: linear-gradient(180deg, rgba(10, 10, 10, 0.15), rgba(10, 10, 10, 0.55))`}
        >
          <div class="flex items-center justify-between pl-4 pr-2 pt-2 text-sm tracking-tight text-[var(--tile-image-text,var(--text-muted))]">
            <span class="py-1.5">Hobby</span>
          </div>
          <div class="p-5">
            <div class="font-serif font-semibold text-xl mb-2 text-[var(--tile-image-text,var(--text))] flex items-center justify-between gap-2">
              <span>Piano</span>
            </div>
            <div class="hobby-list text-sm text-[var(--tile-image-text,var(--text-muted))]">
              <div><span class="label">Currently:</span>Merry Go Round of Life (by Joe Hisaishi)</div>
              <div><span class="label">Next:</span> Talk to me (by Cavetown)</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Reading tiles -->
      {readingPreview.map((book) => (
        <div class="aspect-square px-1 pb-2">
          <div class="group h-full w-full overflow-hidden rounded-[var(--radius-md)] bg-[var(--surface)] transition-colors hover:bg-[var(--surface-2)]">
            <div class="isolate flex h-full w-full flex-col">
              <div class="flex items-center justify-between pl-4 pr-2 pt-2 text-sm tracking-tight text-[var(--text-muted)]">
                <span class="py-1.5">
                  <a
                    href="/reading"
                    class="no-underline border-b-0 transition-colors hover:text-[var(--accent)] hover:underline focus-visible:ring-4 focus-visible:ring-[var(--focus)] focus-visible:underline"
                  >
                    Reading
                  </a>
                  &nbsp;·&nbsp;Books
                </span>
                {book.link && (
                  <a
                    href={book.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex h-8 w-8 items-center justify-center rounded-full transition-colors no-underline border-b-0 focus-visible:ring-4 focus-visible:ring-[var(--focus)] group-focus-within:bg-[var(--text)] group-focus-within:text-[var(--bg)] group-hover:bg-[var(--text)] group-hover:text-[var(--bg)] cursor-alias"
                    aria-label={`View ${book.title} on external site`}
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
                      <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"/>
                    </svg>
                  </a>
                )}
              </div>
              <div class="grid grow grid-cols-2 items-center gap-6 px-7 pb-8">
                <div class="flex h-full items-center">
                  {book.coverImage ? (
                    <img
                      src={urlFor(book.coverImage).width(240).height(360).fit('max').url()}
                      alt={`Cover of ${book.title}`}
                      class="aspect-[3/4] w-full max-h-full rounded object-contain shadow-lg transition-transform group-focus-within:-rotate-3 group-focus-within:scale-110 group-focus-within:shadow-xl group-hover:-rotate-3 group-hover:scale-110 group-hover:shadow-xl border-0"
                      loading="lazy"
                    />
                  ) : (
                    <div class="aspect-[3/4] w-full rounded bg-[var(--surface-2)] shadow-inner"></div>
                  )}
                </div>
                <div class="tracking-tight">
                  <span class="status-chip" data-status="reading">Reading</span>
                  <h3 class="mt-3 line-clamp-3 text-[var(--text)] font-medium leading-snug" style="font-size: 0.875rem;">{book.title}</h3>
                  <span class="text-[var(--text-muted)] text-sm">{book.author}</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}

      {projectTiles.filter(t => t.type !== 'tool').slice(3, 6).map(tile => <GridTile {...tile} />)}
      {postTiles.slice(2, 5).map(tile => <GridTile {...tile} />)}

      <!-- About tile -->
      <div class="aspect-square px-1 pb-2">
        <div class="group h-full w-full overflow-hidden rounded-[var(--radius-md)] bg-[var(--surface)] transition-colors hover:bg-[var(--surface-2)]">
          <a href="/about" class="tile-link flex h-full w-full cursor-pointer flex-col justify-between no-underline border-b-0 text-inherit hover:text-inherit">
            <div class="flex items-center justify-between pl-4 pr-2 pt-2 text-sm tracking-tight text-[var(--text-muted)]">
              <span class="py-1.5">Navigation</span>
              <span class="flex h-8 w-8 items-center justify-center rounded-full transition-colors group-focus-within:bg-[var(--text)] group-focus-within:text-[var(--bg)] group-hover:bg-[var(--text)] group-hover:text-[var(--bg)]">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
                  <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.69l-3.22-3.22a.75.75 0 111.06-1.06l4.5 4.5a.75.75 0 010 1.06l-4.5 4.5a.75.75 0 11-1.06-1.06l3.22-3.22H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
                </svg>
              </span>
            </div>
            <div class="p-5">
              <h3 class="font-serif text-4xl font-light tracking-tight text-[var(--text)]">About</h3>
              <p class="mt-2 text-sm tracking-tight text-[var(--text-muted)]">More about me and my background</p>
            </div>
          </a>
        </div>
      </div>

      <!-- GitHub tile -->
      <div class="aspect-square px-1 pb-2">
        <div class="group h-full w-full overflow-hidden rounded-[var(--radius-md)] bg-[var(--surface)] transition-colors hover:bg-[var(--surface-2)]">
          <a href="https://github.com/Slaymish" target="_blank" rel="noopener noreferrer" class="tile-link flex h-full w-full cursor-alias flex-col justify-between no-underline border-b-0 text-inherit hover:text-inherit">
            <div class="flex items-center justify-between pl-4 pr-2 pt-2 text-sm tracking-tight text-[var(--text-muted)]">
              <span class="py-1.5">External</span>
              <span class="flex h-8 w-8 items-center justify-center rounded-full transition-colors group-focus-within:bg-[var(--text)] group-focus-within:text-[var(--bg)] group-hover:bg-[var(--text)] group-hover:text-[var(--bg)]">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
                  <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"/>
                </svg>
              </span>
            </div>
            <div class="p-5">
              <h3 class="font-serif text-4xl font-light tracking-tight text-[var(--text)]">GitHub</h3>
              <p class="mt-2 text-sm tracking-tight text-[var(--text-muted)]">Check out my code and contributions</p>
            </div>
          </a>
        </div>
      </div>

    </div>

    <!-- View more -->
    <div class="flex justify-center gap-8 mt-8">
      <a href="/tools" class="text-[var(--text-muted)] no-underline border-b-0 text-[0.9375rem] transition-colors hover:text-[var(--accent)]">View all tools →</a>
      <a href="/projects" class="text-[var(--text-muted)] no-underline border-b-0 text-[0.9375rem] transition-colors hover:text-[var(--accent)]">View all projects →</a>
      <a href="/writing" class="text-[var(--text-muted)] no-underline border-b-0 text-[0.9375rem] transition-colors hover:text-[var(--accent)]">View all writing →</a>
    </div>
  </section>

</Layout>

---
import Layout from "../components/layout/Layout.astro";
import { fetchSanity } from "../lib/sanity";

export const prerender = false;

type ProjectDoc = {
  title: string;
  description?: string;
  slug: string;
  date: string;
  technologies?: string[];
  homeTileSize?: 'square' | 'wide';
  relatedPostSlug?: string;
  link?: string;
};

type PostDoc = {
  title: string;
  excerpt?: string;
  slug: string;
  publishedAt: string;
  tags?: string[];
};

type ReportDoc = {
  title: string;
  description?: string;
  slug: string;
  publishedAt: string;
  tags?: string[];
};


const projects = await fetchSanity<ProjectDoc[]>(`
  *[_type == "project"] | order(date desc)[0...8]{
    title,
    description,
    "slug": slug.current,
    date,
    technologies,
    homeTileSize,
    link,
    "relatedPostSlug": relatedPost->slug.current
  }
`);

const posts = await fetchSanity<PostDoc[]>(`
  *[_type == "post"] | order(publishedAt desc)[0...6]{
    title,
    excerpt,
    "slug": slug.current,
    publishedAt,
    tags
  }
`);

const reports = await fetchSanity<ReportDoc[]>(`
  *[_type == "report"] | order(publishedAt desc)[0...6]{
    title,
    description,
    "slug": slug.current,
    publishedAt,
    tags
  }
`);


const homeDescription = "Software engineer building AI infrastructure, self-hosted tools, and full-stack web applications.";

const displayPosts = [
  ...posts.map(p => ({ ...p, _type: 'post' as const })),
  ...reports.map(r => ({ ...r, excerpt: r.description, _type: 'report' as const }))
].sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime());

const featuredProjects = projects.slice(0, 4);
const recentWriting = displayPosts.slice(0, 4);

// Debug: Check if data is loading
console.log('Projects:', projects.length);
console.log('Posts:', posts.length);
console.log('Reports:', reports.length);
---

<Layout title="Hamish Burke" description={homeDescription} fullWidth>

  <!-- ============================================
       HERO — Full viewport, massive bold text
       ============================================ -->
  <section class="home-hero relative flex flex-col justify-center items-center min-h-[90vh] -mt-8 sm:-mt-12 md:-mt-16 mb-0 overflow-hidden">
    <div class="w-full max-w-[90rem] mx-auto px-4 sm:px-8">
      <!-- Invisible reference: the nav logo scales up to align with this exact position -->
      <div class="flex justify-center mb-4 sm:mb-12">
        <div class="home-hero-logo-ref" style="width:180px;height:180px;opacity:0;" aria-hidden="true"></div>
      </div>

      <h1 class="home-hero-heading font-serif font-extrabold text-[var(--text)] leading-[0.92] tracking-[-0.05em] mb-4 sm:mb-12">
        Software engineer.<br class="hidden sm:block" />
        Wellington, NZ.<br class="hidden sm:block" />
        <span class="text-[var(--text-muted)]">AI infrastructure. Self-hosted tools. Full-stack.</span>
      </h1>
      <div class="flex flex-wrap gap-3 sm:gap-6">
        <a
          href="/projects"
          class="cta-primary group inline-flex items-center gap-3 text-base sm:text-lg font-medium text-[var(--accent)] no-underline py-3 px-6 rounded-full border border-[var(--accent)] transition-all duration-300 hover:bg-[var(--accent)] hover:text-[var(--accent-contrast)] hover:opacity-100"
        >
          View work
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.69l-3.22-3.22a.75.75 0 111.06-1.06l4.5 4.5a.75.75 0 010 1.06l-4.5 4.5a.75.75 0 11-1.06-1.06l3.22-3.22H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
          </svg>
        </a>
        <a
          href="/about"
          class="inline-flex items-center gap-3 text-base sm:text-lg font-medium text-[var(--text-muted)] no-underline border-b-0 py-3 px-6 transition-colors duration-300 hover:text-[var(--text)]"
        >
          About me
        </a>
      </div>
    </div>
    <!-- Scroll indicator — hidden on mobile to avoid overlapping CTAs -->
    <div class="hidden sm:flex absolute bottom-8 left-1/2 -translate-x-1/2 flex-col items-center gap-2 text-[var(--text-muted)] opacity-60">
      <span class="text-xs uppercase tracking-[0.15em]">Scroll</span>
      <div class="w-px h-8 bg-[var(--text-muted)] animate-pulse"></div>
    </div>
  </section>

  <!-- ============================================
       SELECTED PROJECTS — Large showcase cards
       ============================================ -->
  <section class="home-section py-16 sm:py-24 md:py-32 max-w-[var(--content-max-width)] mx-auto">
    <div data-reveal>
      <div class="flex items-end justify-between mb-12 sm:mb-16">
        <h2 class="home-section-heading font-serif font-bold text-[var(--text)] tracking-[-0.03em] leading-[1.05] m-0">
          Selected<br />projects
        </h2>
        <a href="/projects" class="hidden sm:inline-flex items-center gap-2 text-sm uppercase tracking-[0.1em] text-[var(--text-muted)] no-underline border-b-0 font-medium transition-colors hover:text-[var(--accent)]">
          All projects
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.69l-3.22-3.22a.75.75 0 111.06-1.06l4.5 4.5a.75.75 0 010 1.06l-4.5 4.5a.75.75 0 11-1.06-1.06l3.22-3.22H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="space-y-6 sm:space-y-8">
      {featuredProjects.map((project, i) => {
        const href = project.relatedPostSlug
          ? `/posts/${project.relatedPostSlug}`
          : `/projects/${project.slug}`;
        const dateStr = new Date(project.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
        return (
          <div data-reveal data-reveal-delay={i * 80}>
            <a
              href={href}
              class="project-card group block no-underline border-b-0 text-inherit hover:text-inherit"
            >
              <article class="relative overflow-hidden rounded-2xl sm:rounded-3xl bg-[var(--surface)] p-6 sm:p-8 md:p-10 transition-all duration-500 hover:bg-[var(--surface-2)] hover:shadow-lg">
                <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 sm:gap-8">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-3 mb-4">
                      <span class="text-xs uppercase tracking-[0.12em] text-[var(--text-muted)] font-medium">{dateStr}</span>
                      {project.technologies?.slice(0, 2).map((tech: string) => (
                        <span class="text-xs uppercase tracking-[0.08em] text-[var(--accent)] font-medium">{tech}</span>
                      ))}
                    </div>
                    <h3 class="font-serif text-3xl sm:text-4xl md:text-5xl font-bold tracking-[-0.03em] text-[var(--text)] leading-[1.1] mb-3 transition-colors duration-300 group-hover:text-[var(--accent)]"
                      transition:name={`title-projects-${project.slug}`}
                    >{project.title}</h3>
                    {project.description && (
                      <p class="text-base sm:text-lg text-[var(--text-muted)] leading-relaxed max-w-[36rem] line-clamp-2 m-0">{project.description}</p>
                    )}
                  </div>
                  <div class="flex-shrink-0 flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-full border border-[var(--border)] transition-all duration-300 group-hover:border-[var(--accent)] group-hover:bg-[var(--accent)] group-hover:text-[var(--accent-contrast)]">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" aria-hidden="true">
                      <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"/>
                    </svg>
                  </div>
                </div>
              </article>
            </a>
          </div>
        );
      })}
    </div>

    <div class="sm:hidden mt-8 text-center">
      <a href="/projects" class="inline-flex items-center gap-2 text-sm uppercase tracking-[0.1em] text-[var(--text-muted)] no-underline border-b-0 font-medium transition-colors hover:text-[var(--accent)]">
        All projects →
      </a>
    </div>
  </section>

  <!-- ============================================
       STATEMENT — Bold typographic section
       ============================================ -->
  <section class="py-20 sm:py-28 md:py-36 max-w-[var(--content-max-width)] mx-auto">
    <div data-reveal>
      <blockquote class="home-statement font-serif font-bold text-[var(--text)] tracking-[-0.03em] leading-[1.1] m-0 p-0 border-0 bg-transparent max-w-[56rem]" style="font-style: normal;">
        I build tools and write about what I learn — sharing knowledge to help others navigate the same challenges.
      </blockquote>
    </div>
    <div data-reveal data-reveal-delay="200">
      <div class="mt-8 sm:mt-12">
        <a href="/writing" class="inline-flex items-center gap-3 text-base sm:text-lg font-medium text-[var(--accent)] no-underline border-b-0 transition-all duration-300 hover:gap-4">
          Read my writing
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.69l-3.22-3.22a.75.75 0 111.06-1.06l4.5 4.5a.75.75 0 010 1.06l-4.5 4.5a.75.75 0 11-1.06-1.06l3.22-3.22H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       RECENT WRITING — Scroll-revealed list
       ============================================ -->
  <section class="home-section py-16 sm:py-24 md:py-32 border-t border-[var(--border)] max-w-[var(--content-max-width)] mx-auto">
    <div data-reveal>
      <div class="flex items-end justify-between mb-12 sm:mb-16">
        <h2 class="home-section-heading font-serif font-bold text-[var(--text)] tracking-[-0.03em] leading-[1.05] m-0">

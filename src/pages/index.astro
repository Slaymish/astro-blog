---
import Layout from '../components/layout/Layout.astro';
import ButtonLink from '../components/ui/ButtonLink.astro';
import ContactBand from '../components/work/ContactBand.astro';
import WorkCard from '../components/work/WorkCard.astro';
import { getWorkStories } from '../lib/workData';
import { BOOKING_URL } from '../lib/site';

export const prerender = false;

const stories = await getWorkStories();
const leadStories = stories.filter((story) => story.status === 'lead');
---

<Layout
  title="Hamish Burke"
  description="Wellington web developer turning unclear requirements and manual processes into digital products, internal tools, and practical automation."
>
  <section class="home-hero">
    <p class="home-hero__eyebrow">Hamish Burke / Web developer at Alphero in Wellington, NZ</p>
    <h1>Software for work that has outgrown the <span>workaround.</span></h1>
    <div class="home-hero__lower">
      <p>
        I turn unclear requirements and manual processes into digital products, internal tools,
        and practical automation.
      </p>
      <div class="home-hero__actions">
        <ButtonLink href="/work">View selected work</ButtonLink>
        <ButtonLink href={BOOKING_URL} external variant="text" ariaLabel="Discuss a project on Cal.com">Discuss a project</ButtonLink>
      </div>
    </div>
    <ul class="home-hero__services" aria-label="Capabilities">
      <li>Product engineering</li>
      <li>Workflow automation</li>
      <li>Technical direction</li>
    </ul>
  </section>

  <section class="home-work" aria-labelledby="selected-work-heading">
    <div class="home-section-heading">
      <div>
        <p>2024-2026</p>
        <h2 id="selected-work-heading">Selected work</h2>
      </div>
      <a href="/work">All work <span aria-hidden="true">→</span></a>
    </div>
    {leadStories.map((story, index) => <WorkCard story={story} reverse={index % 2 === 1} />)}
  </section>

  <section class="home-approach" aria-labelledby="approach-heading">
    <p class="home-approach__label">How I work</p>
    <div>
      <h2 id="approach-heading">I work from the problem outward.</h2>
      <p>
        Define what matters, choose the smallest sound system that solves it, and make the result
        understandable to the people who have to use it. The case studies show the constraints and
        trade-offs, not just the finished surface.
      </p>
      <a href="/about">More about me <span aria-hidden="true">→</span></a>
    </div>
  </section>

  <ContactBand heading="What are you trying to make work?" />
</Layout>

<style>
  .home-hero { display: flex; flex-direction: column; min-height: clamp(32rem, calc(82svh - 8rem), 40rem); padding-block: var(--hero-top-space) var(--spacing-8); }
  .home-hero__eyebrow,
  .home-section-heading p,
  .home-approach__label { color: var(--color-action); font-size: var(--type-label); font-weight: 700; letter-spacing: .1em; margin: 0 0 var(--spacing-5); text-transform: uppercase; }
  .home-hero h1 { font-size: clamp(3.35rem, 9.8vw, 9rem); letter-spacing: -.07em; line-height: .86; margin: 0; max-width: 11ch; }
  .home-hero h1 span { color: var(--color-action); }
  .home-hero__lower { align-items: end; display: grid; gap: var(--spacing-6); margin-block: clamp(2rem, 6vw, 5rem); }
  .home-hero__lower > p { color: var(--color-text-secondary); font-size: clamp(1.05rem, 2vw, 1.35rem); line-height: 1.5; margin: 0; max-width: 38rem; }
  .home-hero__actions { display: flex; flex-wrap: wrap; gap: var(--spacing-3); }
  .home-hero__services { border-top: 1px solid var(--color-stroke-subtle); display: grid; list-style: none; margin: auto 0 0; padding: 0; }
  .home-hero__services li { border-bottom: 1px solid var(--color-stroke-subtle); color: var(--color-text-primary); font-size: var(--type-body-small); font-weight: 600; padding-block: var(--spacing-3); }
  .home-work { margin-block-start: clamp(1.5rem, 3vw, 3rem); }
  .home-section-heading { align-items: end; display: flex; justify-content: space-between; padding-block: var(--spacing-8); }
  .home-section-heading h2 { font-size: clamp(2.3rem, 5vw, 4.5rem); margin: 0; }
  .home-section-heading a { color: var(--color-text-primary); font-size: var(--type-body-small); font-weight: 700; }
  .home-section-heading a:hover { color: var(--color-action); }
  .home-approach { border-block: 1px solid var(--color-stroke-subtle); display: grid; gap: var(--spacing-8); margin-block: clamp(5rem, 12vw, 10rem); padding-block: clamp(3rem, 7vw, 6rem); }
  .home-approach h2 { font-size: clamp(2.5rem, 6vw, 5.5rem); letter-spacing: -.055em; margin: 0; }
  .home-approach div > p { color: var(--color-text-secondary); font-size: clamp(1.05rem, 2vw, 1.3rem); line-height: 1.6; max-width: 43rem; }
  .home-approach a { color: var(--color-text-primary); font-size: var(--type-body-small); font-weight: 700; }
  .home-approach a:hover { color: var(--color-action); }
  @media (min-width: 48rem) {
    .home-hero__lower { grid-template-columns: minmax(0, 1.3fr) minmax(20rem, .7fr); }
    .home-hero__services { grid-template-columns: repeat(3, 1fr); }
    .home-hero__services li { padding-inline: var(--spacing-4); }
    .home-hero__services li:first-child { padding-left: 0; }
    .home-approach { grid-template-columns: minmax(10rem, .45fr) minmax(0, 1.55fr); }
  }
  @media (max-width: 30rem) {
    .home-hero h1 { min-height: 3.44em; }
  }
</style>

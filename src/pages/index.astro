---
import Layout from "../components/layout/Layout.astro";
import { FadeIn } from "../components/motion/FadeIn";
import { fetchSanity, urlFor } from "../lib/sanity";
import Logo from "../components/ui/Logo.astro";

export const prerender = false;

type ProjectDoc = {
  title: string;
  description?: string;
  slug: string;
  date: string;
  technologies?: string[];
  homeTileSize?: 'square' | 'wide';
  relatedPostSlug?: string;
  link?: string;
};

type PostDoc = {
  title: string;
  excerpt?: string;
  slug: string;
  publishedAt: string;
  tags?: string[];
};

type ReportDoc = {
  title: string;
  description?: string;
  slug: string;
  publishedAt: string;
  tags?: string[];
};

type ReadingItem = {
  title: string;
  author: string;
  status: 'reading' | 'read' | 'to-read';
  coverImage?: any;
  link?: string;
};

const projects = await fetchSanity<ProjectDoc[]>(`
  *[_type == "project"] | order(date desc)[0...8]{
    title,
    description,
    "slug": slug.current,
    date,
    technologies,
    homeTileSize,
    link,
    "relatedPostSlug": relatedPost->slug.current
  }
`);

const posts = await fetchSanity<PostDoc[]>(`
  *[_type == "post"] | order(publishedAt desc)[0...6]{
    title,
    excerpt,
    "slug": slug.current,
    publishedAt,
    tags
  }
`);

const reports = await fetchSanity<ReportDoc[]>(`
  *[_type == "report"] | order(publishedAt desc)[0...6]{
    title,
    description,
    "slug": slug.current,
    publishedAt,
    tags
  }
`);

const readingItems = await fetchSanity<ReadingItem[]>(`
  *[_type == "book" && status == "reading"] | order(title asc)[0...2]{
    title,
    author,
    status,
    coverImage,
    link
  }
`);

const homeDescription = "Software engineer building AI infrastructure, self-hosted tools, and full-stack web applications.";

const displayPosts = [
  ...posts.map(p => ({ ...p, _type: 'post' as const })),
  ...reports.map(r => ({ ...r, excerpt: r.description, _type: 'report' as const }))
].sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime());

const featuredProjects = projects.slice(0, 4);
const recentWriting = displayPosts.slice(0, 4);
const readingPreview = readingItems.slice(0, 2);
---

<Layout title="Hamish Burke" description={homeDescription} fullWidth>

  <!-- ============================================
       HERO — Full viewport, massive bold text
       ============================================ -->
  <section class="home-hero relative flex flex-col justify-center items-center min-h-[90vh] -mt-8 sm:-mt-12 md:-mt-16 mb-0 overflow-hidden">
    <div class="w-full max-w-[90rem] mx-auto px-4 sm:px-8">
      <FadeIn client:load delay={0.1} duration={1}>
        <div class="flex justify-center mb-8 sm:mb-12">
          <div class="home-hero-logo-container" style="color: var(--accent);">
            <Logo size={120} class="home-hero-logo" />
          </div>
        </div>
      </FadeIn>
      
      <FadeIn client:load delay={0.15} duration={1}>
        <h1 class="home-hero-heading font-serif font-bold text-[var(--text)] leading-[0.95] tracking-[-0.04em] mb-8 sm:mb-12">
          Software engineer.<br class="hidden sm:block" />
          Wellington, NZ.<br class="hidden sm:block" />
          <span class="text-[var(--text-muted)]">AI infrastructure. Self-hosted tools. Full-stack.</span>
        </h1>
      </FadeIn>
      <FadeIn client:load delay={0.6} duration={0.7}>
        <div class="flex flex-wrap gap-4 sm:gap-6">
          <a
            href="/projects"
            class="cta-primary group inline-flex items-center gap-3 text-base sm:text-lg font-medium text-[var(--accent)] no-underline border-b-0 py-3 px-6 rounded-full border border-[var(--accent)] transition-all duration-300 hover:bg-[var(--accent)] hover:text-[var(--accent-contrast)]"
          >
            View work
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.69l-3.22-3.22a.75.75 0 111.06-1.06l4.5 4.5a.75.75 0 010 1.06l-4.5 4.5a.75.75 0 11-1.06-1.06l3.22-3.22H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
            </svg>
          </a>
          <a
            href="/about"
            class="inline-flex items-center gap-3 text-base sm:text-lg font-medium text-[var(--text-muted)] no-underline border-b-0 py-3 px-6 transition-colors duration-300 hover:text-[var(--text)]"
          >
            About me
          </a>
        </div>
      </FadeIn>
    </div>
    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-[var(--text-muted)] opacity-60">
      <span class="text-xs uppercase tracking-[0.15em]">Scroll</span>
      <div class="w-px h-8 bg-[var(--text-muted)] animate-pulse"></div>
    </div>
  </section>

  <!-- ============================================
       SELECTED PROJECTS — Large showcase cards
       ============================================ -->
  <section class="home-section py-16 sm:py-24 md:py-32 max-w-[var(--content-max-width)] mx-auto">
    <div data-reveal>
      <div class="flex items-end justify-between mb-12 sm:mb-16">
        <h2 class="home-section-heading font-serif font-bold text-[var(--text)] tracking-[-0.03em] leading-[1.05] m-0">
          Selected<br />projects
        </h2>
        <a href="/projects" class="hidden sm:inline-flex items-center gap-2 text-sm uppercase tracking-[0.1em] text-[var(--text-muted)] no-underline border-b-0 font-medium transition-colors hover:text-[var(--accent)]">
          All projects
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.69l-3.22-3.22a.75.75 0 111.06-1.06l4.5 4.5a.75.75 0 010 1.06l-4.5 4.5a.75.75 0 11-1.06-1.06l3.22-3.22H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="space-y-6 sm:space-y-8">
      {featuredProjects.map((project, i) => {
        const href = project.relatedPostSlug
          ? `/posts/${project.relatedPostSlug}`
          : `/projects/${project.slug}`;
        const dateStr = new Date(project.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
        return (
          <div data-reveal data-reveal-delay={i * 80}>
            <a
              href={href}
              class="project-card group block no-underline border-b-0 text-inherit hover:text-inherit"
            >
              <article class="relative overflow-hidden rounded-2xl sm:rounded-3xl bg-[var(--surface)] p-6 sm:p-8 md:p-10 transition-all duration-500 hover:bg-[var(--surface-2)] hover:shadow-lg">
                <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 sm:gap-8">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-3 mb-4">
                      <span class="text-xs uppercase tracking-[0.12em] text-[var(--text-muted)] font-medium">{dateStr}</span>
                      {project.technologies?.slice(0, 2).map((tech: string) => (
                        <span class="text-xs uppercase tracking-[0.08em] text-[var(--accent)] font-medium">{tech}</span>
                      ))}
                    </div>
                    <h3 class="font-serif text-3xl sm:text-4xl md:text-5xl font-bold tracking-[-0.03em] text-[var(--text)] leading-[1.1] mb-3 transition-colors duration-300 group-hover:text-[var(--accent)]"
                      transition:name={`title-projects-${project.slug}`}
                    >{project.title}</h3>
                    {project.description && (
                      <p class="text-base sm:text-lg text-[var(--text-muted)] leading-relaxed max-w-[36rem] line-clamp-2 m-0">{project.description}</p>
                    )}
                  </div>
                  <div class="flex-shrink-0 flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-full border border-[var(--border)] transition-all duration-300 group-hover:border-[var(--accent)] group-hover:bg-[var(--accent)] group-hover:text-[var(--accent-contrast)]">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" aria-hidden="true">
                      <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"/>
                    </svg>
                  </div>
                </div>
              </article>
            </a>
          </div>
        );
      })}
    </div>

    <div class="sm:hidden mt-8 text-center">
      <a href="/projects" class="inline-flex items-center gap-2 text-sm uppercase tracking-[0.1em] text-[var(--text-muted)] no-underline border-b-0 font-medium transition-colors hover:text-[var(--accent)]">
        All projects →
      </a>
    </div>
  </section>

  <!-- ============================================
       STATEMENT — Bold typographic section
       ============================================ -->
  <section class="py-20 sm:py-28 md:py-36 max-w-[var(--content-max-width)] mx-auto">
    <div data-reveal>
      <blockquote class="home-statement font-serif font-bold text-[var(--text)] tracking-[-0.03em] leading-[1.1] m-0 p-0 border-0 bg-transparent max-w-[56rem]" style="font-style: normal;">
        I build tools and write about what I learn — sharing knowledge to help others navigate the same challenges.
      </blockquote>
    </div>
    <div data-reveal data-reveal-delay="200">
      <div class="mt-8 sm:mt-12">
        <a href="/writing" class="inline-flex items-center gap-3 text-base sm:text-lg font-medium text-[var(--accent)] no-underline border-b-0 transition-all duration-300 hover:gap-4">
          Read my writing
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.69l-3.22-3.22a.75.75 0 111.06-1.06l4.5 4.5a.75.75 0 010 1.06l-4.5 4.5a.75.75 0 11-1.06-1.06l3.22-3.22H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       RECENT WRITING — Scroll-revealed list
       ============================================ -->
  <section class="home-section py-16 sm:py-24 md:py-32 border-t border-[var(--border)] max-w-[var(--content-max-width)] mx-auto">
    <div data-reveal>
      <div class="flex items-end justify-between mb-12 sm:mb-16">
        <h2 class="home-section-heading font-serif font-bold text-[var(--text)] tracking-[-0.03em] leading-[1.05] m-0">
          Recent<br />writing
        </h2>
        <a href="/writing" class="hidden sm:inline-flex items-center gap-2 text-sm uppercase tracking-[0.1em] text-[var(--text-muted)] no-underline border-b-0 font-medium transition-colors hover:text-[var(--accent)]">
          All articles
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.69l-3.22-3.22a.75.75 0 111.06-1.06l4.5 4.5a.75.75 0 010 1.06l-4.5 4.5a.75.75 0 11-1.06-1.06l3.22-3.22H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="divide-y divide-[var(--border)]">
      {recentWriting.map((post, i) => {
        const dateStr = new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
        const prefix = post._type === 'report' ? 'reports' : 'posts';
        return (
          <div data-reveal data-reveal-delay={i * 80}>
            <a
              href={`/${prefix}/${post.slug}`}
              class="writing-row group flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-8 py-6 sm:py-8 no-underline border-b-0 text-inherit hover:text-inherit transition-all duration-300"
            >
              <span class="text-sm text-[var(--text-muted)] sm:w-40 flex-shrink-0 uppercase tracking-[0.06em]">{dateStr}</span>
              <div class="flex-1 min-w-0">
                <h3 class="font-serif text-xl sm:text-2xl md:text-3xl font-bold tracking-[-0.02em] text-[var(--text)] leading-tight transition-colors duration-300 group-hover:text-[var(--accent)] m-0"
                  transition:name={`title-${prefix}-${post.slug}`}
                >{post.title}</h3>
                {post.excerpt && (
                  <p class="text-sm sm:text-base text-[var(--text-muted)] mt-2 line-clamp-1 m-0">{post.excerpt}</p>
                )}
              </div>
              <div class="flex-shrink-0 w-10 h-10 rounded-full border border-[var(--border)] flex items-center justify-center transition-all duration-300 opacity-0 group-hover:opacity-100 group-hover:border-[var(--accent)] group-hover:text-[var(--accent)] max-sm:hidden">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
                  <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.69l-3.22-3.22a.75.75 0 111.06-1.06l4.5 4.5a.75.75 0 010 1.06l-4.5 4.5a.75.75 0 11-1.06-1.06l3.22-3.22H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
                </svg>
              </div>
            </a>
          </div>
        );
      })}
    </div>

    <div class="sm:hidden mt-8 text-center">
      <a href="/writing" class="inline-flex items-center gap-2 text-sm uppercase tracking-[0.1em] text-[var(--text-muted)] no-underline border-b-0 font-medium transition-colors hover:text-[var(--accent)]">
        All articles →
      </a>
    </div>
  </section>

  <!-- ============================================
       CURRENTLY READING — Optional section
       ============================================ -->
  {readingPreview.length > 0 && (
    <section class="py-16 sm:py-24 border-t border-[var(--border)] max-w-[var(--content-max-width)] mx-auto">
      <div data-reveal>
        <div class="flex items-end justify-between mb-10 sm:mb-14">
          <h2 class="home-section-heading font-serif font-bold text-[var(--text)] tracking-[-0.03em] leading-[1.05] m-0">
            Currently<br />reading
          </h2>
          <a href="/reading" class="inline-flex items-center gap-2 text-sm uppercase tracking-[0.1em] text-[var(--text-muted)] no-underline border-b-0 font-medium transition-colors hover:text-[var(--accent)]">
            Reading list
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.69l-3.22-3.22a.75.75 0 111.06-1.06l4.5 4.5a.75.75 0 010 1.06l-4.5 4.5a.75.75 0 11-1.06-1.06l3.22-3.22H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
            </svg>
          </a>
        </div>
      </div>

      <div data-reveal>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {readingPreview.map((book, i) => (
            <div data-reveal data-reveal-delay={i * 120}>
              <div class="group flex gap-6 p-6 rounded-2xl bg-[var(--surface)] transition-all duration-300 hover:bg-[var(--surface-2)] hover:shadow-md">
                <div class="flex-shrink-0 w-20 sm:w-24">
                  {book.coverImage ? (
                    <img
                      src={urlFor(book.coverImage).width(240).height(360).fit('max').url()}
                      alt={`Cover of ${book.title}`}
                      class="aspect-[3/4] w-full rounded-lg object-cover shadow-md transition-transform duration-500 group-hover:scale-105 group-hover:-rotate-1 border-0"
                      loading="lazy"
                    />
                  ) : (
                    <div class="aspect-[3/4] w-full rounded-lg bg-[var(--surface-2)] shadow-inner"></div>
                  )}
                </div>
                <div class="flex flex-col justify-center min-w-0">
                  <span class="status-chip mb-3" data-status="reading">Reading</span>
                  <h3 class="font-serif text-lg sm:text-xl font-bold tracking-tight text-[var(--text)] leading-snug m-0 line-clamp-2">{book.title}</h3>
                  <span class="text-sm text-[var(--text-muted)] mt-1">{book.author}</span>
                  {book.link && (
                    <a
                      href={book.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1 text-xs text-[var(--accent)] no-underline border-b-0 mt-3 font-medium transition-colors hover:text-[var(--text)]"
                    >
                      View book
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-3 w-3" aria-hidden="true">
                        <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"/>
                      </svg>
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ============================================
       STAGGERED CTA CARDS — Layered, overlapping
       ============================================ -->
  <section class="home-cta-section relative py-20 sm:py-28 md:py-36 overflow-hidden">
    <div data-reveal>
      <div class="relative max-w-[56rem] mx-auto">

        <!-- Background staggered cards (decorative layers) -->
        <div class="home-cta-stack relative">
          <!-- Card layer 3 (furthest back) -->
          <div class="home-cta-layer home-cta-layer--3 absolute inset-x-6 sm:inset-x-12 -top-6 sm:-top-8 rounded-2xl sm:rounded-3xl bg-[var(--surface-2)] opacity-50 h-full" aria-hidden="true"></div>
          <!-- Card layer 2 -->
          <div class="home-cta-layer home-cta-layer--2 absolute inset-x-3 sm:inset-x-6 -top-3 sm:-top-4 rounded-2xl sm:rounded-3xl bg-[var(--surface)] opacity-75 h-full" aria-hidden="true"></div>
          <!-- Card layer 1 (front) -->
          <div class="home-cta-card relative rounded-2xl sm:rounded-3xl bg-[var(--surface)] p-8 sm:p-12 md:p-16 text-center z-10">
            <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl font-bold tracking-[-0.03em] text-[var(--text)] leading-[1.1] mb-6">
              Let's connect
            </h2>
            <p class="text-base sm:text-lg text-[var(--text-muted)] max-w-[28rem] mx-auto leading-relaxed mb-10 mt-0">
              Currently a Junior Web Developer at <a href="https://www.alphero.com/" target="_blank" rel="noopener noreferrer" class="text-[var(--text-muted)] no-underline border-b-0 hover:text-[var(--accent)] transition-colors">Alphero</a>.
              Always open to interesting conversations and collaborations.
            </p>
            <div class="flex flex-wrap justify-center gap-4">
              <a href="/about" class="home-cta-btn-primary inline-flex items-center gap-2 text-base font-medium no-underline border-b-0 py-3 px-8 rounded-full bg-[var(--accent)] transition-all duration-300 hover:shadow-lg hover:scale-[1.02]">
                About me
              </a>
              <a href="https://github.com/Slaymish" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-base font-medium text-[var(--text)] no-underline border-b-0 py-3 px-8 rounded-full border border-[var(--border)] transition-all duration-300 hover:border-[var(--accent)] hover:text-[var(--accent)]">
                GitHub
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
                  <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"/>
                </svg>
              </a>
              <a href="/tools" class="inline-flex items-center gap-2 text-base font-medium text-[var(--text)] no-underline border-b-0 py-3 px-8 rounded-full border border-[var(--border)] transition-all duration-300 hover:border-[var(--accent)] hover:text-[var(--accent)]">
                Try my tools
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
  /* Primary CTA button — override global a color */
  .home-cta-btn-primary {
    color: #fff !important;
    -webkit-text-fill-color: #fff;
  }

  .home-cta-btn-primary:hover {
    color: #fff !important;
    opacity: 1;
  }

  .home-cta-btn-primary::after {
    display: none !important;
  }

  /* Hero heading — massive responsive type */
  .home-hero-heading {
    font-size: clamp(3.5rem, 12vw, 8rem);
    position: relative;
    z-index: 1;
  }

  /* Prominent hero logo styling */
  .home-hero-logo-container {
    position: relative;
    z-index: 0;
    display: inline-block;
  }

  .home-hero-logo {
    color: var(--accent) !important;
    filter: drop-shadow(0 0 12px var(--accent));
    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .home-hero-logo-container:hover .home-hero-logo {
    transform: scale(1.1) rotate(5deg);
    filter: drop-shadow(0 0 18px var(--accent)) brightness(1.2);
  }

  /* Enhanced glitch effect for hero logo */
  .home-hero-logo-container:hover .logo-glitch {
    opacity: 0.8 !important;
  }

  /* Logo pulse animation */
  @keyframes logo-pulse {
    0%, 100% {
      transform: scale(1);
      filter: drop-shadow(0 0 12px var(--accent));
    }
    50% {
      transform: scale(1.05);
      filter: drop-shadow(0 0 16px var(--accent));
    }
  }

  .home-hero-logo {
    animation: logo-pulse 4s ease-in-out infinite;
  }

  /* Section headings — large but not hero-sized */
  .home-section-heading {
    font-size: clamp(2.5rem, 7vw, 5rem);
  }

  /* Statement quote — large editorial text */
  .home-statement {
    font-size: clamp(2rem, 5vw, 3.5rem);
  }

  /* CTA stacked cards depth effect */
  .home-cta-stack {
    perspective: 1000px;
  }

  .home-cta-layer {
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .home-cta-stack:hover .home-cta-layer--3 {
    transform: translateY(-4px) scale(0.96);
  }

  .home-cta-stack:hover .home-cta-layer--2 {
    transform: translateY(-2px) scale(0.98);
  }

  .home-cta-card {
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.5s ease;
  }

  .home-cta-stack:hover .home-cta-card {
    transform: translateY(-2px);
    box-shadow: 0 20px 60px -15px rgba(0, 0, 0, 0.15);
  }

  :global(.dark) .home-cta-stack:hover .home-cta-card {
    box-shadow: 0 20px 60px -15px rgba(0, 0, 0, 0.5);
  }

  /* Writing row hover padding shift */
  .writing-row {
    padding-left: 0;
    transition: padding-left 0.3s cubic-bezier(0.22, 1, 0.36, 1), color 0.3s ease;
  }

  .writing-row:hover {
    padding-left: 0.5rem;
  }

  /* Project card subtle lift */
  .project-card article {
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
                background-color 0.3s ease,
                box-shadow 0.5s ease;
  }

  .project-card:hover article {
    transform: translateY(-2px);
  }

  /* ── Scroll Reveal (CSS-only initial state) ── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
  }

  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  function initScrollReveal() {
    const els = document.querySelectorAll<HTMLElement>('[data-reveal]');
    if (!els.length) return;

    // Respect reduced motion
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      els.forEach(el => el.classList.add('revealed'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = parseInt(el.dataset.revealDelay || '0', 10);
            if (delay > 0) {
              setTimeout(() => el.classList.add('revealed'), delay);
            } else {
              el.classList.add('revealed');
            }
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    els.forEach((el) => observer.observe(el));
  }

  // Run on initial load and after Astro view transitions
  document.addEventListener('astro:page-load', initScrollReveal);
</script>

<script>
  function initHeroLogoTransition() {
    const heroLogoContainer = document.querySelector<HTMLElement>('.home-hero-logo-container');
    // Target the inner logo wrap — the <a>.nav-logo contains a <span>.hb-logo-wrap
    // whose hb-bounce-in animation (opacity 0→1) overrides any opacity set on the parent.
    const navLogoWrap = document.querySelector<HTMLElement>('.nav-logo .hb-logo-wrap');
    if (!heroLogoContainer || !navLogoWrap) return;

    // Suppress the bounce-in animation and set initial hidden state.
    // animation:none must come first so it wins over the .animate-in class.
    navLogoWrap.style.animation = 'none';
    navLogoWrap.style.opacity = '0';
    navLogoWrap.style.transform = 'scale(0.8) rotate(0deg)';
    navLogoWrap.style.transition = 'opacity 0.35s ease, transform 0.35s ease';

    // Use the actual header height so the nav logo appears exactly when
    // the hero logo finishes sliding behind the sticky header.
    const headerEl = document.getElementById('site-header');
    const headerH = headerEl ? headerEl.getBoundingClientRect().height : 84;
    const rootMargin = `-${Math.round(headerH)}px 0px 0px 0px`;

    const observer = new IntersectionObserver(
      ([entry]) => {
        const heroVisible = entry.isIntersecting;
        navLogoWrap.style.opacity = heroVisible ? '0' : '1';
        navLogoWrap.style.transform = heroVisible ? 'scale(0.8) rotate(0deg)' : 'scale(1) rotate(0deg)';
      },
      { threshold: 0, rootMargin }
    );

    observer.observe(heroLogoContainer);

    // Restore nav logo when navigating away from homepage
    document.addEventListener('astro:before-preparation', () => {
      observer.disconnect();
      navLogoWrap.style.animation = '';
      navLogoWrap.style.opacity = '';
      navLogoWrap.style.transform = '';
      navLogoWrap.style.transition = '';
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initHeroLogoTransition);
</script>

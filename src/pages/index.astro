          All articles
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.69l-3.22-3.22a.75.75 0 111.06-1.06l4.5 4.5a.75.75 0 010 1.06l-4.5 4.5a.75.75 0 11-1.06-1.06l3.22-3.22H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="divide-y divide-[var(--border)]">
      {recentWriting.map((post, i) => {
        const dateStr = new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
        const prefix = post._type === 'report' ? 'reports' : 'posts';
        const isReport = post._type === 'report';
        return (
          <div data-reveal data-reveal-delay={i * 80}>
            <a
              href={`/${prefix}/${post.slug}`}
              class={`writing-row group flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-8 py-6 sm:py-8 no-underline border-b-0 text-inherit hover:text-inherit transition-all duration-300 ${isReport ? 'writing-row--report' : ''}`}
            >
              <div class="flex sm:flex-col sm:items-start gap-3 sm:gap-1 sm:w-40 flex-shrink-0">
                <span class={`type-badge ${isReport ? 'type-badge--report' : 'type-badge--post'}`}>
                  {isReport ? 'Report' : 'Post'}

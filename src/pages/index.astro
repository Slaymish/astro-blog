                >{post.title}</h3>
                {post.excerpt && (
                  <p class="text-sm sm:text-base text-[var(--text-muted)] mt-2 line-clamp-1 m-0">{post.excerpt}</p>
                )}
              </div>
              <div class="flex-shrink-0 w-10 h-10 rounded-full border border-[var(--border)] flex items-center justify-center transition-all duration-300 opacity-0 group-hover:opacity-100 group-hover:border-[var(--accent)] group-hover:text-[var(--accent)] max-sm:hidden">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
                  <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.69l-3.22-3.22a.75.75 0 111.06-1.06l4.5 4.5a.75.75 0 010 1.06l-4.5 4.5a.75.75 0 11-1.06-1.06l3.22-3.22H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
                </svg>
              </div>
            </a>
          </div>
        );
      })}
    </div>

    <div class="sm:hidden mt-8 text-center">
      <a href="/writing" class="inline-flex items-center gap-2 text-sm uppercase tracking-[0.1em] text-[var(--text-muted)] no-underline border-b-0 font-medium transition-colors hover:text-[var(--accent)]">
        All articles →
      </a>
    </div>
  </section>

  <!-- ============================================
       READING LINK — Compact inline link
       ============================================ -->
  <section class="py-10 sm:py-12 border-t border-[var(--border)] max-w-[var(--content-max-width)] mx-auto">
    <div data-reveal>
      <a href="/reading" class="group inline-flex items-center gap-3 no-underline border-b-0">
        <span class="text-xs uppercase tracking-[0.15em] text-[var(--text-muted)] font-medium">Currently reading</span>
        <span class="w-px h-4 bg-[var(--border)]"></span>
        <span class="text-base font-medium text-[var(--text)] transition-colors duration-200 group-hover:text-[var(--accent)]">
          See my reading list
        </span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 text-[var(--text-muted)] transition-all duration-300 group-hover:text-[var(--accent)] group-hover:translate-x-1" aria-hidden="true">
          <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.69l-3.22-3.22a.75.75 0 111.06-1.06l4.5 4.5a.75.75 0 010 1.06l-4.5 4.5a.75.75 0 11-1.06-1.06l3.22-3.22H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ============================================
       STAGGERED CTA CARDS — Layered, overlapping
       ============================================ -->
  <section class="home-cta-section relative py-20 sm:py-28 md:py-36 overflow-hidden">
    <div data-reveal>
      <div class="relative max-w-[56rem] mx-auto">

        <!-- Background staggered cards (decorative layers) -->
        <div class="home-cta-stack relative">
          <!-- Card layer 3 (furthest back) -->
          <div class="home-cta-layer home-cta-layer--3 absolute inset-x-6 sm:inset-x-12 -top-6 sm:-top-8 rounded-2xl sm:rounded-3xl bg-[var(--surface-2)] opacity-50 h-full" aria-hidden="true"></div>
          <!-- Card layer 2 -->
          <div class="home-cta-layer home-cta-layer--2 absolute inset-x-3 sm:inset-x-6 -top-3 sm:-top-4 rounded-2xl sm:rounded-3xl bg-[var(--surface)] opacity-75 h-full" aria-hidden="true"></div>
          <!-- Card layer 1 (front) -->
          <div class="home-cta-card relative rounded-2xl sm:rounded-3xl bg-[var(--surface)] p-8 sm:p-12 md:p-16 text-center z-10">
            <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl font-bold tracking-[-0.03em] text-[var(--text)] leading-[1.1] mb-6">
              Let's connect
            </h2>
            <p class="text-base sm:text-lg text-[var(--text-muted)] max-w-[28rem] mx-auto leading-relaxed mb-10 mt-0">
              Currently a Junior Web Developer at <a href="https://www.alphero.com/" target="_blank" rel="noopener noreferrer" class="text-[var(--text-muted)] no-underline border-b-0 hover:text-[var(--accent)] transition-colors">Alphero</a>.
              Always open to interesting conversations and collaborations.
            </p>
            <div class="flex flex-wrap justify-center gap-4">
              <a href="/about" class="home-cta-btn-primary inline-flex items-center gap-2 text-base font-medium no-underline border-b-0 py-3 px-8 rounded-full bg-[var(--accent)] transition-all duration-300 hover:shadow-lg hover:scale-[1.02]">
                About me
              </a>
              <a href="https://github.com/Slaymish" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-base font-medium text-[var(--text)] no-underline border-b-0 py-3 px-8 rounded-full border border-[var(--border)] transition-all duration-300 hover:border-[var(--accent)] hover:text-[var(--accent)]">
                GitHub
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
                  <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"/>
                </svg>
              </a>
              <a href="/tools" class="inline-flex items-center gap-2 text-base font-medium text-[var(--text)] no-underline border-b-0 py-3 px-8 rounded-full border border-[var(--border)] transition-all duration-300 hover:border-[var(--accent)] hover:text-[var(--accent)]">
                Try my tools
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
  /* Primary CTA button — override global a color */
  .home-cta-btn-primary {
    color: var(--accent-contrast) !important;
    -webkit-text-fill-color: var(--accent-contrast);
  }

  .home-cta-btn-primary:hover {
    color: var(--accent-contrast) !important;
    opacity: 1;
  }

  .home-cta-btn-primary::after {
    display: none !important;
  }

  /* Hero heading — massive responsive type */
  .home-hero-heading {
    font-size: clamp(2.5rem, 11vw, 9.5rem);
  }

  /* Section headings — large but not hero-sized */
  .home-section-heading {
    font-size: clamp(2.5rem, 7vw, 5rem);
  }

  /* Statement quote — large editorial text */
  .home-statement {
    font-size: clamp(2rem, 5vw, 3.5rem);
  }

  /* CTA stacked cards depth effect */
  .home-cta-stack {
    perspective: 1000px;
  }

  .home-cta-layer {
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .home-cta-stack:hover .home-cta-layer--3 {
    transform: translateY(-4px) scale(0.96);
  }

  .home-cta-stack:hover .home-cta-layer--2 {
    transform: translateY(-2px) scale(0.98);
  }

  .home-cta-card {
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.5s ease;
  }

  .home-cta-stack:hover .home-cta-card {
    transform: translateY(-2px);
    box-shadow: 0 20px 60px -15px rgba(0, 0, 0, 0.15);
  }

  :global(.dark) .home-cta-stack:hover .home-cta-card {
    box-shadow: 0 20px 60px -15px rgba(0, 0, 0, 0.5);
  }

  /* Writing row hover padding shift */
  .writing-row {
    padding-left: 0;
    transition: padding-left 0.3s cubic-bezier(0.22, 1, 0.36, 1), color 0.3s ease;
  }

  .writing-row:hover {
    padding-left: 0.5rem;
  }

  /* Report rows get a distinct left accent */
  .writing-row--report {
    border-left: 2px solid transparent;
    padding-left: 1rem;
    margin-left: -1rem;
    transition: border-color 0.3s ease, padding-left 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .writing-row--report:hover {
    border-left-color: var(--border-strong);
    padding-left: 1.5rem;
  }

  /* Type badges */
  .type-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    flex-shrink: 0;
  }

  .type-badge--post {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
  }

  .type-badge--report {
    background: color-mix(in srgb, var(--text-muted) 12%, transparent);
    color: var(--text-muted);
  }

  /* Project card subtle lift */
  .project-card article {
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
                background-color 0.3s ease,
                box-shadow 0.5s ease;
  }

  .project-card:hover article {
    transform: translateY(-2px);
  }

  /* ── Scroll Reveal (CSS-only initial state) ── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
  }

  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  function initScrollReveal() {
    const els = document.querySelectorAll<HTMLElement>('[data-reveal]');
    if (!els.length) return;

    // Respect reduced motion
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      els.forEach(el => el.classList.add('revealed'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = parseInt(el.dataset.revealDelay || '0', 10);
            if (delay > 0) {
              setTimeout(() => el.classList.add('revealed'), delay);
            } else {
              el.classList.add('revealed');
            }
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    els.forEach((el) => observer.observe(el));
  }

  // Run on initial load and after Astro view transitions
  document.addEventListener('astro:page-load', initScrollReveal);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollReveal);
  } else {
    initScrollReveal();
  }
</script>


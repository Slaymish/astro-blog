---
import Layout from "../../components/layout/Layout.astro";
import { fetchSanity } from "../../lib/sanity";
import { createSlug } from "../../utils/slug";

export const prerender = false;

type TagPath = { tag: string };

type PostDoc = {
  title: string;
  slug: string;
  publishedAt: string;
  excerpt?: string;
  tags?: string[];
};

type ReportDoc = {
  title: string;
  slug: string;
  publishedAt: string;
  description?: string;
  tags?: string[];
};

const { tag } = Astro.params as TagPath;

const allTags = await fetchSanity<string[]>(`
  array::unique(*[_type in ["post", "report"]].tags[])
`);

const tagLabel = allTags.find((entry) => createSlug(entry) === tag) ?? tag ?? '';

const posts = tagLabel
  ? await fetchSanity<PostDoc[]>(`
      *[_type == "post" && $tag in tags] | order(publishedAt desc){
        title,
        "slug": slug.current,
        publishedAt,
        excerpt,
        tags
      }
    `, { tag: tagLabel })
  : [];

const reports = tagLabel
  ? await fetchSanity<ReportDoc[]>(`
      *[_type == "report" && $tag in tags] | order(publishedAt desc){
        title,
        "slug": slug.current,
        publishedAt,
        description,
        tags
      }
    `, { tag: tagLabel })
  : [];

const totalItems = posts.length + reports.length;
const displayTag = tagLabel || tag || '';
---

<Layout
  title={`Content tagged "${displayTag}"`}
  description={`Browse writing and reports tagged ${displayTag} on Hamish Burke's site.`}
>
  <div class="max-w-4xl mx-auto">
    <div class="mb-12">
      <h1 class="text-4xl font-bold mb-4 text-[var(--text)]">
        Content tagged "{displayTag}"
      </h1>
      <p class="mb-4 text-[var(--text-muted)]">
        {totalItems} {totalItems === 1 ? 'item' : 'items'} found
      </p>
      <a href="/" class="text-[var(--accent)] hover:underline no-underline border-b-0">
        ← Back to home
      </a>
    </div>

    {reports.length > 0 && (
      <section class="mb-12">
        <h2 class="text-3xl font-bold mb-6 text-[var(--text)]">
          Reports ({reports.length})
        </h2>
        <div class="space-y-8">
          {reports.map((report) => (
            <article class="pb-8 border-b border-[var(--border)]">
              <h3 class="text-2xl font-bold mb-2">
                <a
                  href={`/reports/${report.slug}`}
                  class="text-[var(--text)] hover:text-[var(--accent)] no-underline border-b-0 transition-colors"
                >
                  {report.title}
                </a>
              </h3>
              <p class="mb-4 text-[var(--text-muted)]">
                {new Date(report.publishedAt).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric"
                })}
              </p>
              {report.description && (
                <p class="mb-4 text-[var(--text-muted)]">
                  {report.description}
                </p>
              )}
              {report.tags && report.tags.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {report.tags.map((t) => (
                    <a
                      href={`/tags/${createSlug(t)}`}
                      class="text-sm px-3 py-1 rounded-full bg-[var(--surface-2)] text-[var(--text-muted)] no-underline border-b-0 hover:text-[var(--accent)] transition-colors"
                    >
                      {t}
                    </a>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    {posts.length > 0 && (
      <section>
        <h2 class="text-3xl font-bold mb-6 text-[var(--text)]">
          Posts ({posts.length})
        </h2>
        <div class="space-y-8">
          {posts.map((post) => (
            <article class="pb-8 border-b border-[var(--border)]">
              <h3 class="text-2xl font-bold mb-2">
                <a
                  href={`/posts/${post.slug}`}
                  class="text-[var(--text)] hover:text-[var(--accent)] no-underline border-b-0 transition-colors"
                >
                  {post.title}
                </a>
              </h3>
              <p class="mb-4 text-[var(--text-muted)]">
                {new Date(post.publishedAt).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric"
                })}
              </p>
              {post.excerpt && (
                <p class="mb-4 text-[var(--text-muted)]">
                  {post.excerpt}
                </p>
              )}
              {post.tags && post.tags.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {post.tags.map((t) => (
                    <a
                      href={`/tags/${createSlug(t)}`}
                      class="text-sm px-3 py-1 rounded-full bg-[var(--surface-2)] text-[var(--text-muted)] no-underline border-b-0 hover:text-[var(--accent)] transition-colors"
                    >
                      {t}
                    </a>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    {totalItems === 0 && (
      <div class="text-center py-12">
        <h2 class="text-2xl font-bold mb-4 text-[var(--text)]">
          No content found
        </h2>
        <p class="text-[var(--text-muted)]">
          There is no content tagged with "{displayTag}" yet.
        </p>
      </div>
    )}
  </div>
</Layout>

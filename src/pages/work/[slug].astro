---
import Layout from '../../components/layout/Layout.astro';
import ButtonLink from '../../components/ui/ButtonLink.astro';
import MediaFrame from '../../components/ui/MediaFrame.astro';
import ContactBand from '../../components/work/ContactBand.astro';
import WorkGraphic from '../../components/work/WorkGraphic.astro';
import { portableTextToHtml } from '../../lib/portableText';
import { SITE_URL, absoluteUrl } from '../../lib/site';
import { artifactHref, type WorkArtifact } from '../../lib/work';
import { getWorkStory } from '../../lib/workData';

export const prerender = false;

const slug = Astro.params.slug as string;
const story = await getWorkStory(slug);

if (!story) {
  return new Response('Work story not found', { status: 404 });
}

const storySlug = story.slug;
const body = portableTextToHtml(story.body);
const artifacts = [story.primaryArtifact, ...story.supportingArtifacts].filter(Boolean);
const soleArtifact = artifacts.length === 1 ? artifacts[0] : undefined;
const sourceHeading = soleArtifact?.liveUrl
  ? 'Live site'
  : soleArtifact?.type === 'report'
    ? 'Project report'
    : artifacts.length > 1
      ? 'Project links'
      : 'Project link';
const sourceDescription = soleArtifact?.liveUrl
  ? 'See the finished project in use.'
  : soleArtifact?.type === 'report'
    ? 'Read the original project report.'
    : 'Explore the project source and related writing.';

function artifactUrl(artifact: WorkArtifact) {
  const externalUrl = artifact.githubUrl || artifact.liveUrl;
  if (externalUrl) return externalUrl;

  const url = artifactHref(artifact);
  return artifact.type === 'post'
    ? `${url}?from=${encodeURIComponent(`/work/${storySlug}`)}`
    : url;
}

function isExternal(url: string) {
  return url.startsWith('http');
}
---

<Layout
  title={`${story.title} — ${story.descriptor}`}
  description={story.summary}
  canonicalURL={absoluteUrl(`/work/${story.slug}`, SITE_URL)}
  article
  publishedTime={`${story.date}T00:00:00.000Z`}
>
  <article class="case-study">
    <header class="case-study__hero">
      <p class="case-study__eyebrow">{story.descriptor} · {story.timeframe ?? new Date(story.date).getFullYear()}</p>
      <h1>{story.title}</h1>
      <p class="case-study__summary">{story.summary}</p>
      {artifacts.length > 0 && (
        <div class="case-study__links">
          {artifacts.map((artifact, index) => {
            const url = artifactUrl(artifact!);
            return (
              <ButtonLink
                href={url}
                external={isExternal(url)}
                variant={index === 0 ? 'primary' : 'secondary'}
              >
                {index === 0 ? 'View the evidence' : artifact!.title}
              </ButtonLink>
            );
          })}
        </div>
      )}
    </header>

    <div class="case-study__graphic">
      <WorkGraphic kind={story.graphic.kind} alt={story.graphic.alt} priority />
    </div>

    <section class="case-snapshot" aria-labelledby="case-snapshot-heading">
      <h2 id="case-snapshot-heading">Case snapshot</h2>
      <dl>
        <div><dt>Problem</dt><dd>{story.problem}</dd></div>
        <div><dt>My role</dt><dd>{story.role}</dd></div>
        <div><dt>What I changed</dt><dd><ul>{story.interventions.map((item) => <li>{item}</li>)}</ul></dd></div>
        <div class="case-snapshot__result"><dt>Result</dt><dd>{story.result}</dd></div>
      </dl>
    </section>

    <section class="case-study__story" aria-label="Case study detail">
      <p class="case-study__section-label">Context, decisions, and evidence</p>
      <div class="prose case-study__body" set:html={body} />
    </section>

    {story.graphic.kind === 'brontehf' && (
      <section class="case-study__evidence" aria-labelledby="publishing-workflow-heading">
        <div class="case-study__evidence-heading">
          <p class="case-study__section-label">Publishing workflow</p>
          <h2 id="publishing-workflow-heading">Edit and preview in one place</h2>
        </div>
        <MediaFrame
          src="/images/work/bronte-cms.webp"
          alt="The BrontëHF project editor beside a live preview of the Tei project page."
          width={2541}
          height={1231}
          caption="Project content can be edited while checking the published result in the same workspace."
          ratio="natural"
        />
      </section>
    )}

    {artifacts.length > 0 && (
      <section class="case-study__sources" aria-labelledby="source-material-heading">
        <h2 id="source-material-heading">{sourceHeading}</h2>
        <p>{sourceDescription}</p>
        <ul>
          {artifacts.map((artifact) => {
            const url = artifactUrl(artifact!);
            return <li><a href={url} target={isExternal(url) ? '_blank' : undefined} rel={isExternal(url) ? 'noopener noreferrer' : undefined}>{artifact!.title} <span aria-hidden="true">{isExternal(url) ? '↗' : '→'}</span></a></li>;
          })}
        </ul>
      </section>
    )}

    <a class="case-study__back" href="/work">← All work</a>
  </article>

  <ContactBand heading="Need a system like this?" />
</Layout>

<style>
  .case-study__hero { padding-block: var(--hero-top-space) var(--hero-bottom-space); }
  .case-study__eyebrow,
  .case-study__section-label { color: var(--color-action); font-size: var(--type-label); font-weight: 700; letter-spacing: .1em; margin: 0 0 var(--spacing-5); text-transform: uppercase; }
  .case-study__hero h1 { font-size: var(--type-display); letter-spacing: -.065em; line-height: .88; margin: 0; max-width: 12ch; }
  .case-study__summary { color: var(--color-text-secondary); font-size: clamp(1.2rem, 2.5vw, 1.7rem); line-height: 1.4; margin: var(--spacing-8) 0 0; max-width: 34rem; }
  .case-study__links { display: flex; flex-wrap: wrap; gap: var(--spacing-3); margin-top: var(--spacing-8); }
  .case-study__graphic :global(.work-graphic) { margin-inline: auto; max-width: 54rem; }
  .case-study__graphic :global(.work-graphic--brontehf) { aspect-ratio: 2550 / 1231; max-height: none; }
  .case-snapshot { margin-block: clamp(4rem, 10vw, 9rem); }
  .case-snapshot > h2 { font-size: clamp(2.3rem, 5vw, 4.5rem); margin: 0 0 var(--spacing-8); }
  .case-snapshot dl { border-top: 1px solid var(--color-stroke-subtle); margin: 0; }
  .case-snapshot dl > div { border-bottom: 1px solid var(--color-stroke-subtle); display: grid; gap: var(--spacing-3); padding-block: clamp(1.5rem, 4vw, 2.5rem); }
  .case-snapshot dt { color: var(--color-action); font-size: var(--type-label); font-weight: 700; letter-spacing: .09em; text-transform: uppercase; }
  .case-snapshot dd { color: var(--color-text-primary); font-size: clamp(1.05rem, 2vw, 1.3rem); line-height: 1.5; margin: 0; max-width: 48rem; }
  .case-snapshot ul { display: grid; gap: var(--spacing-3); list-style: none; margin: 0; padding: 0; }
  .case-snapshot li { padding-left: var(--spacing-5); position: relative; }
  .case-snapshot li::before { color: var(--color-action); content: '→'; left: 0; position: absolute; }
  .case-snapshot__result dd { color: var(--color-action); }
  .case-study__story { display: grid; gap: var(--spacing-8); margin-block: clamp(5rem, 12vw, 10rem); }
  .case-study__body { max-width: 48rem; }
  .case-study__body :global(h2) { font-size: clamp(1.8rem, 3vw, 2.7rem); margin-top: clamp(3rem, 7vw, 5rem); }
  .case-study__body :global(h2:first-child) { margin-top: 0; }
  .case-study__body :global(p) { color: var(--color-text-secondary); font-size: clamp(1.05rem, 1.5vw, 1.2rem); line-height: 1.7; }
  .case-study__evidence { display: grid; gap: var(--spacing-8); margin-block: clamp(5rem, 12vw, 10rem); }
  .case-study__evidence-heading h2 { font-size: clamp(2rem, 4vw, 3.5rem); margin: 0; max-width: 15ch; }
  .case-study__evidence-heading .case-study__section-label { margin-bottom: var(--spacing-3); }
  .case-study__sources { border-block: 1px solid var(--color-stroke-subtle); padding-block: clamp(2.5rem, 6vw, 4.5rem); }
  .case-study__sources h2 { font-size: clamp(2rem, 4vw, 3.5rem); margin: 0; }
  .case-study__sources p { color: var(--color-text-secondary); max-width: 38rem; }
  .case-study__sources ul { display: grid; gap: var(--spacing-3); list-style: none; margin: var(--spacing-6) 0 0; padding: 0; }
  .case-study__sources a { color: var(--color-text-primary); font-weight: 700; }
  .case-study__sources a:hover { color: var(--color-action); }
  .case-study__back { color: var(--color-text-secondary); display: inline-flex; font-size: var(--type-body-small); margin-top: var(--spacing-8); }
  @media (min-width: 48rem) {
    .case-snapshot dl > div { grid-template-columns: minmax(8rem, .4fr) minmax(0, 1.6fr); }
    .case-study__story { grid-template-columns: minmax(10rem, .45fr) minmax(0, 1.55fr); }
  }
</style>

---
import Layout from '../components/layout/Layout.astro';
import MediaFrame from '../components/ui/MediaFrame.astro';
import ContactBand from '../components/work/ContactBand.astro';
import { SITE_URL, absoluteUrl } from '../lib/site';
---

<Layout
  title="About Hamish Burke"
  description="Software engineer in Wellington working across digital products, AI systems, infrastructure, and the interfaces that make them useful."
  canonicalURL={absoluteUrl('/about', SITE_URL)}
>
  <article class="about">
    <header class="about__hero">
      <p class="about__eyebrow">About · Wellington, New Zealand</p>
      <h1>I like understanding the whole system.</h1>
      <p class="about__intro">
        I’m Hamish, a software engineer who works from the underlying problem through to the interface
        people actually use. I’m most useful when the brief is complicated, the path is unclear, and a
        practical result matters more than technical theatre.
      </p>
    </header>

    <section class="about__portrait" aria-label="Introduction">
      <MediaFrame
        src="/images/headshot.jpg"
        alt="Hamish Burke in Wellington"
        width={3264}
        height={4896}
        ratio="portrait"
        position="center top"
        loading="eager"
      />
      <div>
        <p class="about__label">Current context</p>
        <p class="about__large-copy">
          I work at <a href="https://www.alphero.com/" target="_blank" rel="noopener noreferrer">Alphero</a>
          as a web developer and take on a small number of independent projects.
        </p>
        <p>
          My public portfolio deliberately excludes NDA-covered client work. The work shown here is what
          I can discuss honestly: finished freelance delivery, products I have built end to end, and
          technical studies with enough evidence to inspect.
        </p>
      </div>
    </section>

    <section class="about__capabilities" aria-labelledby="capabilities-heading">
      <div class="about__section-heading">
        <p class="about__label">What I bring</p>
        <h2 id="capabilities-heading">Breadth with a point.</h2>
      </div>
      <ol>
        <li><span>01</span><div><h3>Product delivery</h3><p>Responsive interfaces, content systems, integrations, and the release path needed to make them maintainable.</p></div></li>
        <li><span>02</span><div><h3>Systems thinking</h3><p>Data models, APIs, infrastructure, security boundaries, and recovery plans shaped around the real constraint.</p></div></li>
        <li><span>03</span><div><h3>Technical clarity</h3><p>Plain-language decisions, visible trade-offs, and enough documentation for someone else to operate the result.</p></div></li>
      </ol>
    </section>

    <section class="about__background" aria-labelledby="background-heading">
      <p class="about__label">Background</p>
      <div>
        <h2 id="background-heading">Research taught me to be precise. Building taught me to ship.</h2>
        <p>
          I completed a Master of Computer Science at Victoria University of Wellington. My thesis studied
          diffusion-based anomaly detection for electrical distribution networks. That work sharpened how I
          frame uncertain problems, evaluate evidence, and separate an interesting result from a useful one.
        </p>
        <p>
          Outside software, I boulder, play piano, and read widely. Those are good counterweights to work that
          can otherwise become entirely screens and abstractions.
        </p>
        <nav aria-label="About links">
          <a href="/cv">View CV →</a>
          <a href="/work">Selected work →</a>
          <a href="https://github.com/Slaymish" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
          <a href="https://www.linkedin.com/in/hamish-burke-2301669a" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
        </nav>
      </div>
    </section>
  </article>

  <ContactBand heading="Want to talk through a problem?" />

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': absoluteUrl('/#person', SITE_URL),
    name: 'Hamish Burke',
    url: absoluteUrl('/', SITE_URL),
    image: absoluteUrl('/images/headshot.jpg', SITE_URL),
    jobTitle: 'Web Developer',
    worksFor: { '@type': 'Organization', name: 'Alphero', url: 'https://www.alphero.com/' },
    alumniOf: { '@type': 'EducationalOrganization', name: 'Victoria University of Wellington', sameAs: 'https://www.wgtn.ac.nz' },
    knowsAbout: ['Software Engineering', 'Artificial Intelligence', 'Distributed Systems', 'System Architecture', 'Full-Stack Development'],
    sameAs: ['https://github.com/Slaymish', 'https://www.linkedin.com/in/hamish-burke-2301669a'],
    mainEntityOfPage: { '@type': 'ProfilePage', '@id': absoluteUrl('/about', SITE_URL) }
  })} />
</Layout>

<style>
  .about__hero { padding-block: var(--hero-top-space) var(--hero-bottom-space); }
  .about__eyebrow,
  .about__label { color: var(--color-action); font-size: var(--type-label); font-weight: 700; letter-spacing: .1em; margin: 0 0 var(--spacing-5); text-transform: uppercase; }
  .about__hero h1 { font-size: var(--type-display); letter-spacing: -.065em; line-height: .88; margin: 0; max-width: 10ch; }
  .about__intro { color: var(--color-text-secondary); font-size: clamp(1.15rem, 2.2vw, 1.5rem); line-height: 1.5; margin-top: var(--spacing-8); max-width: 44rem; }
  .about__portrait { align-items: center; border-top: 1px solid var(--color-stroke-subtle); display: grid; gap: clamp(2rem, 7vw, 6rem); padding-block: clamp(3rem, 9vw, 8rem); }
  .about__portrait :global(.media-frame) { max-width: 28rem; }
  .about__portrait p { color: var(--color-text-secondary); line-height: 1.7; }
  .about__portrait .about__large-copy { color: var(--color-text-primary); font-size: clamp(1.5rem, 3vw, 2.5rem); line-height: 1.3; margin-top: 0; }
  .about__portrait a { color: var(--color-action); }
  .about__capabilities { margin-block: clamp(4rem, 10vw, 9rem); }
  .about__section-heading { margin-bottom: var(--spacing-8); }
  .about__section-heading h2,
  .about__background h2 { font-size: clamp(2.4rem, 6vw, 5.5rem); letter-spacing: -.055em; margin: 0; max-width: 13ch; }
  .about__capabilities ol { border-top: 1px solid var(--color-stroke-subtle); list-style: none; margin: 0; padding: 0; }
  .about__capabilities li { border-bottom: 1px solid var(--color-stroke-subtle); display: grid; gap: var(--spacing-5); grid-template-columns: 2rem 1fr; padding-block: clamp(1.5rem, 4vw, 2.75rem); }
  .about__capabilities li > span { color: var(--color-action); font-family: var(--font-mono); font-size: .7rem; }
  .about__capabilities h3 { font-size: clamp(1.5rem, 3vw, 2.5rem); margin: 0; }
  .about__capabilities p { color: var(--color-text-secondary); line-height: 1.6; margin: var(--spacing-3) 0 0; max-width: 42rem; }
  .about__background { border-block: 1px solid var(--color-stroke-subtle); display: grid; gap: var(--spacing-8); padding-block: clamp(3rem, 8vw, 7rem); }
  .about__background div > p { color: var(--color-text-secondary); font-size: clamp(1.05rem, 1.5vw, 1.2rem); line-height: 1.7; max-width: 44rem; }
  .about__background nav { display: flex; flex-wrap: wrap; gap: var(--spacing-3) var(--spacing-6); margin-top: var(--spacing-8); }
  .about__background nav a { align-items: center; color: var(--color-text-primary); display: inline-flex; font-size: var(--type-body-small); font-weight: 700; min-height: 2.75rem; }
  .about__background nav a:hover { color: var(--color-action); }
  @media (min-width: 48rem) {
    .about__portrait { grid-template-columns: minmax(16rem, .75fr) minmax(0, 1.25fr); }
    .about__capabilities li { grid-template-columns: 3rem minmax(0, 1fr); }
    .about__background { grid-template-columns: minmax(10rem, .45fr) minmax(0, 1.55fr); }
  }
</style>

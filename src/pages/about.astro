---
import Layout from '../components/layout/Layout.astro';
import { SITE_URL, absoluteUrl, CONTACT_EMAIL } from '../lib/site';
---

<Layout
  title="About Hamish Burke"
  description="Junior Web Developer at Alphero. MSc Computer Science from Victoria University of Wellington. Interests in AI, distributed systems, and full-stack development."
  canonicalURL={absoluteUrl('/about', SITE_URL)}
>
  <article
    class="max-w-3xl mx-auto"
    itemscope
    itemtype="http://schema.org/AboutPage"
  >
    <header class="mb-12">
      <h1
        class="font-serif text-[clamp(2.5rem,6vw,4rem)] font-bold tracking-[-0.03em] text-[var(--text)]"
        itemprop="name"
      >
        About Me
      </h1>
    </header>

    <div
      class="max-w-none"
      itemprop="mainContentOfPage"
    >
      <!-- Bio -->
      <section class="mb-16">
        <p class="mb-5 text-lg text-[var(--text-muted)] leading-[1.8]">
          I'm Hamish, a software engineer based in Wellington, New Zealand. I recently completed my Master of Computer Science
          at Victoria University of Wellington, where my thesis focused on anomaly detection of electrical distribution networks
          using diffusion methods.
        </p>
        <p class="mb-5 text-lg text-[var(--text-muted)] leading-[1.8]">
          I now work at <a href="https://www.alphero.com/" target="_blank" rel="noopener noreferrer" class="text-[var(--accent)] no-underline hover:opacity-80 transition-colors">Alphero</a> as a Junior Web Developer. My broader interests sit at the intersection of AI, infrastructure,
          and systems thinking. I've built tools for GPU sharing and distributed computing, self-hosted applications, and
          full-stack web platforms. I'm drawn to problems that require understanding systems end-to-end, from the hardware
          layer through to the user interface.
        </p>
        <p class="text-lg text-[var(--text-muted)] leading-[1.8]">
          Outside of code, you'll find me bouldering at the local climbing gym, learning piano pieces by Joe Hisaishi,
          or reading about whatever has caught my attention that week.
        </p>
      </section>

      <!-- Currently -->
      <section class="mb-16 p-6 rounded-[var(--radius-lg)] bg-[var(--surface)] border border-[var(--border)]">
        <h2 class="font-serif text-2xl font-semibold mb-6 text-[var(--text)] tracking-tight">
          Currently
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 text-sm">
          <div>
            <span class="block text-[var(--text-muted)] font-medium mb-1 uppercase tracking-wider text-xs">Working</span>
            <span class="text-[var(--text)]">Junior Web Developer at <a href="https://www.alphero.com/" target="_blank" rel="noopener noreferrer" class="text-[var(--text)] no-underline hover:text-[var(--accent)] hover:opacity-100 transition-colors">Alphero</a></span>
          </div>
          <div>
            <span class="block text-[var(--text-muted)] font-medium mb-1 uppercase tracking-wider text-xs">Building</span>
            <span class="text-[var(--text)]">GPUShare, distributed GPU sharing for ML workloads</span>
          </div>
          <div>
            <span class="block text-[var(--text-muted)] font-medium mb-1 uppercase tracking-wider text-xs">Learning</span>
            <span class="text-[var(--text)]">Piano, Merry Go Round of Life by Joe Hisaishi</span>
          </div>
          <div>
            <span class="block text-[var(--text-muted)] font-medium mb-1 uppercase tracking-wider text-xs">Reading</span>
            <span class="text-[var(--text)]"><a href="/reading" class="no-underline border-b-0 hover:text-[var(--accent)] transition-colors">See my reading list →</a></span>
          </div>
        </div>
      </section>

      <!-- What I Work With -->
      <section class="mb-16">
        <h2 class="font-serif text-2xl font-semibold mb-6 text-[var(--text)] tracking-tight">
          What I Work With
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h3 class="text-lg font-semibold mb-3 text-[var(--text)]">
              Languages & Frameworks
            </h3>
            <ul class="list-disc list-inside text-[var(--text-muted)] space-y-1.5">
              <li>Python, TypeScript, JavaScript, Java, C++</li>
              <li>React, Astro, Next.js</li>
              <li>Node.js, Express</li>
              <li>SQL, NoSQL databases</li>
            </ul>
          </div>
          <div>
            <h3 class="text-lg font-semibold mb-3 text-[var(--text)]">
              Tools & Technologies
            </h3>
            <ul class="list-disc list-inside text-[var(--text-muted)] space-y-1.5">
              <li>Docker, Kubernetes</li>
              <li>Git, CI/CD pipelines</li>
              <li>Cloud platforms (AWS, GCP)</li>
              <li>Machine Learning (PyTorch, TensorFlow)</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Get in Touch -->
      <section class="mb-16">
        <h2 class="font-serif text-2xl font-semibold mb-6 text-[var(--text)] tracking-tight">
          Get in Touch
        </h2>
        <p class="text-[var(--text-muted)] mb-6 leading-[1.7]">
          The best way to reach me is by email. You can also find me on GitHub and LinkedIn.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href={`mailto:${CONTACT_EMAIL}`}
            class="inline-flex items-center gap-2.5 px-5 py-2.5 rounded-[var(--radius-md)] border border-[var(--border)] text-[var(--text)] no-underline border-b-[1px] font-medium transition-all hover:border-[var(--accent)] hover:text-[var(--accent)]"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            Email me
          </a>
          <a
            href="https://github.com/Slaymish"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2.5 px-5 py-2.5 rounded-[var(--radius-md)] border border-[var(--border)] text-[var(--text)] no-underline border-b-[1px] font-medium transition-all hover:border-[var(--accent)] hover:text-[var(--accent)]"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
          <a
            href="https://www.linkedin.com/in/hamish-burke-2301669a"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2.5 px-5 py-2.5 rounded-[var(--radius-md)] border border-[var(--border)] text-[var(--text)] no-underline border-b-[1px] font-medium transition-all hover:border-[var(--accent)] hover:text-[var(--accent)]"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
          <a
            href="/cv"
            class="inline-flex items-center gap-2.5 px-5 py-2.5 rounded-[var(--radius-md)] border border-[var(--border)] text-[var(--text)] no-underline border-b-[1px] font-medium transition-all hover:border-[var(--accent)] hover:text-[var(--accent)]"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
            View CV
          </a>
        </div>
      </section>

      <!-- This Website -->
      <section>
        <h2 class="font-serif text-2xl font-semibold mb-6 text-[var(--text)] tracking-tight">
          This Website
        </h2>
        <p class="text-[var(--text-muted)] leading-[1.7]">
          Built with <a href="https://astro.build" target="_blank" rel="noopener" class="text-[var(--accent)] no-underline border-b border-transparent hover:border-[var(--accent)] transition-colors">Astro</a>,
          content managed with Sanity CMS, styled with Tailwind CSS, and deployed on Netlify.
          The source is on <a href="https://github.com/Slaymish/astro-blog" target="_blank" rel="noopener" class="text-[var(--accent)] no-underline border-b border-transparent hover:border-[var(--accent)] transition-colors">GitHub</a>.
        </p>
      </section>
    </div>
  </article>

  <!-- Enhanced Schema.org markup for About page -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": absoluteUrl('/#person', SITE_URL),
    "name": "Hamish Burke",
    "alternateName": ["Slaymish", "hamishburke.studio"],
    "url": absoluteUrl('/', SITE_URL),
    "image": absoluteUrl('/apple-touch-icon.png', SITE_URL),
    "jobTitle": "Junior Web Developer",
    "worksFor": {
      "@type": "Organization",
      "name": "Alphero",
      "url": "https://www.alphero.com/"
    },
    "description": "Junior Web Developer at Alphero. MSc Computer Science from Victoria University of Wellington, specializing in AI and full-stack development.",
    "alumniOf": {
      "@type": "EducationalOrganization",
      "name": "Victoria University of Wellington",
      "sameAs": "https://www.wgtn.ac.nz"
    },
    "knowsAbout": [
      "Software Engineering",
      "Artificial Intelligence", 
      "Machine Learning",
      "Distributed Systems",
      "System Architecture",
      "Full-Stack Development",
      "Python Programming",
      "TypeScript",
      "Docker",
      "Kubernetes",
      "Cloud Infrastructure",
      "Database Design",
      "DevOps"
    ],
    "knowsLanguage": ["en-NZ", "en-US"],
    "nationality": {
      "@type": "Country",
      "name": "New Zealand"
    },
    "sameAs": [
      "https://github.com/Slaymish",
      "https://www.linkedin.com/in/hamish-burke-2301669a",
      "https://twitter.com/Slaymishh",
      "https://instagram.com/hamishburke.studio"
    ],
    "mainEntityOfPage": {
      "@type": "ProfilePage",
      "@id": absoluteUrl('/about', SITE_URL)
    }
  })} />
</Layout>


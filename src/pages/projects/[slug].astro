---
import Layout from "../../components/layout/Layout.astro";
import ParallaxHero from "../../components/features/ParallaxHero.astro";
import { fetchSanity } from "../../lib/sanity";
import { portableTextToHtml } from "../../lib/portableText";

export const prerender = false;

type ProjectDoc = {
  title: string;
  description?: string;
  slug: string;
  date?: string;
  technologies?: string[];
  link?: string;
  github?: string;
  body?: any;
  relatedPostSlug?: string;
  relatedPostTitle?: string;
};

const { slug } = Astro.params;

const project = await fetchSanity<ProjectDoc | null>(`
  *[_type == "project" && slug.current == $slug][0]{
    title,
    description,
    "slug": slug.current,
    date,
    technologies,
    link,
    github,
    body,
    "relatedPostSlug": relatedPost->slug.current,
    "relatedPostTitle": relatedPost->title
  }
`, { slug });

if (!project) {
  return Astro.redirect('/404');
}

const projectTitle = project.title;
const projectDescription = project.description;
const technologies = project.technologies || [];
const link = project.link;
const github = project.github;
const relatedPostSlug = project.relatedPostSlug;
const relatedPostTitle = project.relatedPostTitle;
const htmlContent = portableTextToHtml(project.body);
---

<Layout
  title={`${projectTitle} | Project`}
  description={projectDescription}
  fullWidth
>
  <ParallaxHero
    title={projectTitle}
    subtitle={projectDescription}
    label="Project"
    date={project.date}
    tags={technologies}
    titleTransitionName={`title-projects-${project.slug}`}
    backHref="/projects"
    backLabel="Projects"
  />

  <!-- Action bar -->
  <div class="proj-actions" data-reveal>
    <div class="proj-actions__inner">
      {relatedPostSlug && (
        <a href={`/posts/${relatedPostSlug}`} class="proj-btn proj-btn--primary">
          Read the write-up
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.69l-3.22-3.22a.75.75 0 111.06-1.06l4.5 4.5a.75.75 0 010 1.06l-4.5 4.5a.75.75 0 11-1.06-1.06l3.22-3.22H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
          </svg>
        </a>
      )}
      {link && (
        <a href={link} target="_blank" rel="noopener noreferrer" class="proj-btn">
          Live Demo
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"/>
          </svg>
        </a>
      )}
      {github && (
        <a href={github} target="_blank" rel="noopener noreferrer" class="proj-btn">
          GitHub
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"/>
          </svg>
        </a>
      )}
    </div>
  </div>

  <!-- Body content -->
  {htmlContent && (
    <article class="proj-body" data-reveal>
      <div class="prose" set:html={htmlContent}></div>
    </article>
  )}

  <!-- Related post callout -->
  {relatedPostSlug && (
    <div class="proj-related" data-reveal>
      <div class="proj-related__inner">
        <span class="proj-related__label">Related article</span>
        <h3 class="proj-related__title">
          <a href={`/posts/${relatedPostSlug}`}>{relatedPostTitle || 'Read the write-up'}</a>
        </h3>
        <span class="proj-related__arrow">→</span>
      </div>
    </div>
  )}

  <!-- Footer nav -->
  <nav class="proj-footer" data-reveal aria-label="Project navigation">
    <a href="/projects" class="proj-footer__link">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
        <path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd"/>
      </svg>
      All projects
    </a>
  </nav>
</Layout>

<style>
  /* ── Action bar ── */
  .proj-actions {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem 0;
  }

  @media (min-width: 640px) {
    .proj-actions { padding: 3rem 2rem 0; }
  }

  .proj-actions__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .proj-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 9999px;
    color: var(--text);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9375rem;
    transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .proj-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .proj-btn::after {
    display: none !important;
  }

  .proj-btn--primary {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  .proj-btn--primary:hover {
    opacity: 0.9;
    color: #fff;
  }

  /* ── Body ── */
  .proj-body {
    max-width: var(--reading-width, 65ch);
    margin: 3rem auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 640px) {
    .proj-body {
      margin: 4rem auto;
      padding: 0 2rem;
    }
  }

  .proj-body .prose {
    max-width: none;
  }

  /* ── Related post ── */
  .proj-related {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 640px) {
    .proj-related { padding: 0 2rem; }
  }

  .proj-related__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem 2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    transition: border-color 0.2s ease;
  }

  .proj-related__inner:hover {
    border-color: var(--accent);
  }

  .proj-related__label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    white-space: nowrap;
  }

  .proj-related__title {
    flex: 1;
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0;
    color: var(--text);
  }

  .proj-related__title a {
    color: inherit;
    text-decoration: none;
    border-bottom: none;
  }

  .proj-related__title a::after {
    display: none !important;
  }

  .proj-related__title a:hover {
    color: var(--accent);
  }

  .proj-related__arrow {
    color: var(--text-muted);
    font-size: 1.25rem;
    transition: transform 0.2s ease;
  }

  .proj-related__inner:hover .proj-related__arrow {
    transform: translateX(4px);
    color: var(--accent);
  }

  /* ── Footer nav ── */
  .proj-footer {
    max-width: var(--content-max-width);
    margin: 3rem auto 0;
    padding: 2rem 1.5rem 0;
    border-top: 1px solid var(--border);
  }

  @media (min-width: 640px) {
    .proj-footer { padding: 3rem 2rem 0; }
  }

  .proj-footer__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9375rem;
    transition: color 0.2s ease, gap 0.2s ease;
  }

  .proj-footer__link:hover {
    color: var(--accent);
    gap: 0.75rem;
  }

  .proj-footer__link::after {
    display: none !important;
  }

  /* ── data-reveal for this page ── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  function initProjectReveal() {
    const els = document.querySelectorAll<HTMLElement>('[data-reveal]:not([data-parallax-hero] [data-reveal])');
    if (!els.length) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      els.forEach(el => el.classList.add('revealed'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    els.forEach(el => observer.observe(el));
  }

  document.addEventListener('astro:page-load', initProjectReveal);
</script>

---
import Layout from "../../components/layout/Layout.astro";
import { fetchSanity } from "../../lib/sanity";

export const prerender = false;

type ToolDoc = {
  title: string;
  description?: string;
  slug: string;
  date: string;
  technologies?: string[];
  link: string;
  github?: string;
  relatedPostSlug?: string;
};

const tools = await fetchSanity<ToolDoc[]>(`
  *[_type == "project" && defined(link) && link != ""] | order(date desc){
    title,
    description,
    "slug": slug.current,
    date,
    technologies,
    link,
    github,
    "relatedPostSlug": relatedPost->slug.current
  }
`);
---

<Layout
  title="Tools"
  description="Live tools and apps you can use right now — built by Hamish Burke."
>
  <div class="max-w-[var(--container-xl)] mx-auto">
    <header class="mb-12">
      <h1 class="font-serif text-[clamp(2.5rem,6vw,4rem)] font-bold tracking-[-0.03em] text-[var(--text)]">
        tools.
      </h1>
      <p class="max-w-[40rem] text-xl text-[var(--text-muted)] leading-[1.6]">
        Live tools and apps you can use right now.
      </p>
    </header>

    {tools.length > 0 ? (
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {tools.map((tool) => (
          <div class="tool-card group relative flex flex-col rounded-[var(--radius-md)] bg-[var(--surface)] border border-[var(--border)] overflow-hidden transition-all duration-200 hover:border-[var(--accent)] hover:shadow-md">
            <div class="flex items-center justify-between px-5 pt-5 pb-3">
              <span class="inline-flex items-center gap-1.5 text-xs font-medium text-[var(--accent)] uppercase tracking-[0.08em]">
                <span class="inline-block w-1.5 h-1.5 rounded-full bg-[var(--accent)]"></span>
                Live
              </span>
              <span class="text-xs text-[var(--text-muted)]">
                {new Date(tool.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
              </span>
            </div>

            <div class="flex-1 px-5 pb-5">
              <h2 class="font-serif text-2xl font-light tracking-tight text-[var(--text)] mb-2 leading-snug">
                {tool.title}
              </h2>
              {tool.description && (
                <p class="text-sm text-[var(--text-muted)] leading-relaxed line-clamp-3 mb-4">
                  {tool.description}
                </p>
              )}

              {tool.technologies && tool.technologies.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mb-5">
                  {tool.technologies.map((tech: string) => (
                    <span class="rounded px-2 py-0.5 bg-[var(--surface-2)] text-[var(--text-muted)] text-xs">
                      {tech}
                    </span>
                  ))}
                </div>
              )}

              <div class="flex flex-wrap gap-2 mt-auto pt-2">
                <a
                  href={tool.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="launch-btn inline-flex items-center gap-2 px-4 py-2 rounded-[var(--radius-base)] bg-[var(--accent)] text-sm font-medium no-underline transition-opacity hover:opacity-90"
                  style="color: #fff !important; text-decoration: none;"
                >
                  Launch
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-3.5 w-3.5" aria-hidden="true">
                    <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"/>
                  </svg>
                </a>
                {tool.relatedPostSlug && (
                  <a
                    href={`/posts/${tool.relatedPostSlug}`}
                    class="inline-flex items-center gap-1.5 px-4 py-2 rounded-[var(--radius-base)] border border-[var(--border)] text-[var(--text-muted)] text-sm font-medium no-underline transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)]"
                    style="text-decoration: none;"
                  >
                    Read write-up
                  </a>
                )}
                {tool.github && (
                  <a
                    href={tool.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 px-4 py-2 rounded-[var(--radius-base)] border border-[var(--border)] text-[var(--text-muted)] text-sm font-medium no-underline transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)]"
                    style="text-decoration: none;"
                  >
                    GitHub
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="text-center py-20 text-[var(--text-muted)]">
        <p class="text-lg mb-2">No live tools yet.</p>
        <p class="text-sm opacity-70">Check back soon — things are being built.</p>
      </div>
    )}
  </div>
</Layout>

---
import Layout from "../../components/layout/Layout.astro";
import { fetchSanity, urlFor } from "../../lib/sanity";

export const prerender = false;

type ReadingStatus = 'reading' | 'read' | 'to-read';

type ReadingItem = {
  title: string;
  author: string;
  status: ReadingStatus;
  coverImage?: any;
  link?: string;
};

const readingItems = await fetchSanity<ReadingItem[]>(`
  *[_type == "book"] | order(status asc, title asc){
    title,
    author,
    status,
    coverImage,
    link
  }
`);

const statusLabel: Record<ReadingStatus, string> = {
  reading: 'Reading',
  read: 'Read',
  'to-read': 'To read'
};
---

<Layout
  title="Reading"
  description="What I'm reading, what I've read, and what I hope to read next."
>
  <div class="max-w-[var(--container-xl)] mx-auto">
    <header class="mb-10">
      <h1 class="font-serif text-[clamp(3rem,7vw,4.5rem)] font-bold tracking-[-0.03em] text-[var(--text)]" transition:name="page-heading">
        reading.
      </h1>
      <p class="max-w-[40rem] text-xl text-[var(--text-muted)] leading-[1.6]">
        What I'm reading, what I've read, and what I hope to read next.
        Recommendations are always welcome.
      </p>
    </header>

    <section
      class="grid grid-cols-[repeat(auto-fit,minmax(240px,1fr))] gap-5"
      aria-label="Reading list"
    >
      {readingItems.sort((a, b) => {
        const order = ['to-read', 'reading', 'read'];
        return order.indexOf(a.status) - order.indexOf(b.status);
      }).map((item) => (
        <article class="bg-[var(--surface)] rounded-[var(--tile-radius)] p-4 grid gap-3 min-h-64" style="box-shadow: var(--shadow-neu);">

          <!-- Meta row -->
          <div class="flex justify-between text-xs text-[var(--text-muted)] uppercase tracking-[0.08em]">
            <span>Reading · Books</span>
            <span aria-hidden="true">
              {item.link ? (
                <a href={item.link} target="_blank" rel="noopener noreferrer" class="no-underline border-b-0 hover:text-[var(--accent)]">↗</a>
              ) : (
                <span>•</span>
              )}
            </span>
          </div>

          <!-- Body -->
          <div class="grid grid-cols-[80px_1fr] gap-[0.9rem] items-start max-sm:grid-cols-[72px_1fr]">
            <div
              class="w-full rounded-[0.2rem] overflow-hidden bg-[var(--surface-2)] flex items-center justify-center transition-transform duration-200"
              data-has-cover={item.coverImage ? 'true' : 'false'}
              style="data-has-cover='true' && 'hover:rotate-[2deg] hover:scale-[1.03]'"
            >
              {item.link ? (
                <a href={item.link} target="_blank" rel="noopener noreferrer" class="block w-full h-full no-underline border-b-0 text-inherit">
                  {item.coverImage ? (
                    <img
                      src={urlFor(item.coverImage).width(240).height(320).fit('crop').url()}
                      alt={`Cover of ${item.title}`}
                      loading="lazy"
                      class="w-full h-full object-cover border-0"
                    />
                  ) : (
                    <div
                      class="w-[70%] h-[70%] rounded-[0.35rem]"
                      style="background: linear-gradient(135deg, rgba(246,82,160,0.2), rgba(99,102,241,0.15));"
                      aria-hidden="true"
                    />
                  )}
                </a>
              ) : (
                <>
                  {item.coverImage ? (
                    <img
                      src={urlFor(item.coverImage).width(240).height(320).fit('crop').url()}
                      alt={`Cover of ${item.title}`}
                      loading="lazy"
                      class="w-full h-full object-cover border-0"
                    />
                  ) : (
                    <div
                      class="w-[70%] h-[70%] rounded-[0.35rem]"
                      style="background: linear-gradient(135deg, rgba(246,82,160,0.2), rgba(99,102,241,0.15));"
                      aria-hidden="true"
                    />
                  )}
                </>
              )}
            </div>

            <div>
              <span class="status-chip" data-status={item.status}>
                {statusLabel[item.status]}
              </span>
              <h2 class="mt-[0.6rem] mb-1 text-[var(--text)]" style="font-size: 1rem; font-weight: 600; line-height: 1.4; letter-spacing: normal;">{item.title}</h2>
              <p class="m-0 text-[var(--text-muted)] text-[0.9rem]">{item.author}</p>
            </div>
          </div>

        </article>
      ))}
    </section>
  </div>
</Layout>
